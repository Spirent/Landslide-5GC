                <item guid="605768ad-ce70-4894-a071-203c4d4f2e16" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Delete the DMF file </body>
                    </command>
                    <nestedSteps>
                        <item guid="9387ab9e-9037-4ef2-ae6e-a72fa1e1791b" action="if" useFieldsInCommand="false">
                            <command>
                                <body>int(data_trans) !=int(default_data_trans) or int(data_tps) !=int(default_data_tps):</body>
                            </command>
                            <nestedSteps>
                                <item guid="9b8aa5b2-d8f5-430f-b065-5da3ac88b1b7" action="Custom" session="s1">
                                    <command>
                                        <body>-requestMethod DELETE -dataType xml -rawResponse true -url libraries/[user_lib_id]/dmfs/[dmf_name_file]</body>
                                    </command>
                                    <postProcessing>
                                        <analysisRules>
                                            <item>
                                                <extractorInfo extractorType="query">
                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                        <query>success()</query>
                                                    </extractorProperties>
                                                </extractorInfo>
                                                <processorInfo ruleType="assert">
                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                        <expression>value == &quot;true&quot;</expression>
                                                        <actionsWhenTrue>
                                                            <item actionId="SkipRemainingRules">
                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                            </item>
                                                        </actionsWhenTrue>
                                                    </ruleProperties>
                                                </processorInfo>
                                            </item>
                                            <item>
                                                <extractorInfo extractorType="query">
                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                        <query>mapped/Json/reason</query>
                                                    </extractorProperties>
                                                </extractorInfo>
                                                <processorInfo ruleType="assert">
                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                        <expression>True</expression>
                                                        <actionsWhenTrue>
                                                            <item actionId="DeclareExecutionIssue">
                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.ExecutionIssuePropertyGroup" severity="Warning">
                                                                    <message>{value}</message>
                                                                </actionProperties>
                                                            </item>
                                                        </actionsWhenTrue>
                                                    </ruleProperties>
                                                </processorInfo>
                                            </item>
                                        </analysisRules>
                                        <storeResponseAt>dmf_body</storeResponseAt>
                                        <storeResponseText>true</storeResponseText>
                                    </postProcessing>
                                    <applicationProperties type="com.fnfr.itest.platform2.shared.documents.ntaf.NtafTransferableDocumentObject" action="Custom" subharness="http://spirent.com/NTAF/harness/iTest/LandslideRest/Main" harness="http://spirent.com/NTAF/harness/iTest/LandslideRest/Main" harnessName="http://spirent.com/NTAF/harness/iTest/LandslideRest/Main" requestMethod="DELETE" requestMethod.inherit="false" dataType="xml" dataType.inherit="false" rawResponse="true" rawResponse.inherit="false" url="libraries/[user_lib_id]/dmfs/[dmf_name_file]" url.inherit="false"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="b5c9aa5f-8f15-48a4-8f86-1997ab7eb040" action="return">
                    <command>
                        <body>[response]</body>
                    </command>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
            </steps>
            <arguments>
                <item name="run_data">
                    <isMandatory>true</isMandatory>
                </item>
                <item name="t_load"/>
                <item name="t_rate"/>
                <item name="running_node_id"/>
                <item name="is_b2b">
                    <defaultValue>true</defaultValue>
                    <isMandatory>true</isMandatory>
                </item>
                <item name="timeout">
                    <defaultValue>180</defaultValue>
                </item>
            </arguments>
            <response>{}</response>
        </item>
        <item name="validate_KPIs" isPublic="true">
            <steps>
                <item guid="467da7dd-357c-4905-9268-20bec87b5512" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Get KPIs</body>
                    </command>
                    <nestedSteps>
                        <item guid="3db84082-43a5-4233-8612-bcff50244757" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>print(measurement_favorites)</body>
                            </command>
                            <postProcessing>
                                <analysisRules>
                                    <item>
                                        <extractorInfo extractorType="query">
                                            <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                <query>count(mapped/Json/favorites/item)</query>
                                            </extractorProperties>
                                        </extractorInfo>
                                        <processorInfo ruleType="assert">
                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                <expression>int(value) &gt; 0</expression>
                                                <actionsWhenFalse>
                                                    <item actionId="Eval">
                                                        <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                                            <statement>total_packets_sent = total_sent_packets_discarded = error_indications_received = invalid_error_indications_received = basic_data_messages_sent = basic_data_messages_received= &quot;&quot;</statement>
                                                        </actionProperties>
                                                    </item>
                                                    <item actionId="SkipRemainingRules">
                                                        <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                    </item>
                                                </actionsWhenFalse>
                                            </ruleProperties>
                                        </processorInfo>
                                    </item>
                                    <item>
                                        <extractorInfo extractorType="query">
                                            <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                <query>//gNB_User_Node__Total_Packets_Sent</query>
                                            </extractorProperties>
                                        </extractorInfo>
                                        <processorInfo ruleType="store">
                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                                <storageLocation>total_packets_sent</storageLocation>
                                                <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                                <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                                <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                            </ruleProperties>
                                        </processorInfo>
                                    </item>
                                    <item>
                                        <extractorInfo extractorType="query">
                                            <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                <query>//gNB_User_Node__Total_Sent_Packets_Discarded</query>
                                            </extractorProperties>
                                        </extractorInfo>
                                        <processorInfo ruleType="store">
                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                                <storageLocation>total_sent_packets_discarded</storageLocation>
                                                <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                                <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                                <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                            </ruleProperties>
                                        </processorInfo>
                                    </item>
                                    <item>
                                        <extractorInfo extractorType="query">
                                            <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                <query>//gNB_User_Node__Error_Indications_Received</query>
                                            </extractorProperties>
                                        </extractorInfo>
                                        <processorInfo ruleType="store">
                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                                <storageLocation>error_indications_received</storageLocation>
                                                <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                                <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                                <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                            </ruleProperties>
                                        </processorInfo>
                                    </item>
                                    <item>
                                        <extractorInfo extractorType="query">
                                            <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                <query>//gNB_User_Node__Invalid_Error_Indications_Received</query>
                                            </extractorProperties>
                                        </extractorInfo>
                                        <processorInfo ruleType="store">
                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                                <storageLocation>invalid_error_indications_received</storageLocation>
                                                <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                                <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                                <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                            </ruleProperties>
                                        </processorInfo>
                                    </item>
                                    <item>
                                        <extractorInfo extractorType="query">
                                            <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                <query>//L5-7_Client_Basic__Basic_Data_Messages_Sent</query>
                                            </extractorProperties>
                                        </extractorInfo>
                                        <processorInfo ruleType="store">
                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                                <storageLocation>basic_data_messages_sent</storageLocation>
                                                <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                                <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                                <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                            </ruleProperties>
                                        </processorInfo>
                                    </item>
                                    <item>
                                        <extractorInfo extractorType="query">
                                            <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                <query>//L5-7_Client_Basic__Basic_Data_Messages_Received</query>
                                            </extractorProperties>
                                        </extractorInfo>
                                        <processorInfo ruleType="store">
                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                                <storageLocation>basic_data_messages_received</storageLocation>
                                                <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                                <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                                <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                            </ruleProperties>
                                        </processorInfo>
                                    </item>
                                </analysisRules>
                                <storeResponseAt>measurement_xml</storeResponseAt>
                            </postProcessing>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="d4d1f8e7-d295-4bd8-9e4a-8c834096f500" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Create KPIs response</body>
                    </command>
                    <nestedSteps>
                        <item guid="b3d1bea6-2d44-4b7b-8a7e-5a0d9ee2bbc4" action="json" useFieldsInCommand="false">
                            <command>
                                <body>action=&apos;createJson&apos;, documentName=&apos;response&apos;, fromFile=false, jsonString=&apos;{&quot;result&quot;:&quot;PASS&quot;,&quot;KPIs&quot;:[]}&apos;</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.execution.builtin.json.JsonPropertiesGroup">
                                <action inherit="false">createJson</action>
                                <jsonString inherit="false">{&quot;result&quot;:&quot;PASS&quot;,&quot;KPIs&quot;:[]}</jsonString>
                                <documentName inherit="false">response</documentName>
                            </applicationProperties>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="dce43e70-2ab0-435d-bc1a-c4dc4031aa26" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Calculate if needed</body>
                    </command>
                    <nestedSteps>
                        <item guid="89cd7d37-ae1f-4b08-a811-ba3d728c1678" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>delta = math.ceil(t_load * 3 / 100)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="500ed4b0-dc49-47c3-863e-202264900ee7" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>t_load = int(t_load)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="56e89c06-2b72-497b-8da5-9783ee5c027f" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>fuzz_load = int(t_load/int(fuzz_rate))</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="085181ba-2c0f-4434-a409-9d27b3074480" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>value1_kpi_value = error_indications_received</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="a8e2edd5-ac89-4ac7-a1bc-162f8c9d75fc" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>lower_bound = max(math.floor(fuzz_load - delta), 0)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="9fd1d541-0886-40ed-956e-d9cd23f8c252" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>upper_bound = math.ceil(fuzz_load + delta)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="3daf525b-b498-4ac3-a065-112752abc8af" action="if" useFieldsInCommand="false">
                            <command>
                                <body>upper_bound &gt; t_load:</body>
                            </command>
                            <nestedSteps>
                                <item guid="48fabf3a-6f20-4801-8214-4d5836c55adb" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>upper_bound = t_load</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="879e26ab-bb07-4f8c-854c-6c88c8d93c4a" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>value2_kpi_value = t_load - int(value1_kpi_value)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="42429ff1-4ecb-4f4a-b36e-d4603cc9f40e" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Check acceptance</body>
                    </command>
                    <nestedSteps>
                        <item guid="fec3b7ae-641f-40e9-92c1-bf4aac7f6d75" action="comment" useFieldsInCommand="false">
                            <command>
                                <body>Total Packets Sent</body>
                            </command>
                            <nestedSteps>
                                <item guid="eaac77c1-e289-4b5e-91a3-83f0113ca2f6" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>key_tag = &quot;Total Packets Sent&quot;</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="a86d1151-817f-4888-9502-c81e3c631a87" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>unit = &quot;&quot;</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="de75dbb7-8e07-4d1c-983c-974ebd27cb55" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>expected = t_load</body>
                                    </command>
