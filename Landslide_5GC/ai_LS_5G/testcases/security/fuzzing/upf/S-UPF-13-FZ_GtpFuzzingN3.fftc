                                        <item guid="6e8cf2b7-7705-418c-be11-d88afb6a4ef8" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>reason = &quot;Unknown error. Nodal test state: {0}&quot;.format(testsession_state)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="4ca50d1f-3a94-472e-b8f7-3dc75d232d81" action="json" useFieldsInCommand="false">
                                    <command>
                                        <body>action=&apos;addJsonNode&apos;, editResponseStructure=false, documentName=&apos;response&apos;, pathValue=&apos;{&quot;/&quot;:{&quot;reason&quot;:&quot;[reason]&quot;}}&apos;</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.execution.builtin.json.JsonPropertiesGroup" pathValue="{&quot;/&quot;:{&quot;reason&quot;:&quot;[reason]&quot;}}" pathValue.inherit="false" pathValue.sub="true">
                                        <action inherit="false">addJsonNode</action>
