                        <item guid="927cbb3d-373c-4c60-a922-7e1035579a38" action="Custom" session="s1">
                            <command>
                                <body>-requestMethod GET -dataType json -rawResponse true -url runningTests/[running_nodal_id]</body>
                            </command>
                            <postProcessing>
