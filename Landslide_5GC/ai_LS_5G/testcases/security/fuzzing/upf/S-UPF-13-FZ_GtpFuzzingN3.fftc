        <item name="create_dmf_file" isPublic="true">
            <steps>
                <item guid="d1da855b-2122-4b3e-9c65-dee7089e9f72" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Get the sample DMF content as xml from the original test</body>
                    </command>
                    <nestedSteps>
                        <item guid="46657194-a725-4356-aaf5-dccaa35da494" action="Custom" session="s1">
                            <command>
                                <body>-requestMethod GET -dataType xml -rawResponse true -url libraries/[library_id]/dmfs/[dmf_name]?as=xml</body>
                            </command>
                            <postProcessing>
                                <storeResponseAt>dmf_body</storeResponseAt>
                                <storeResponseText>true</storeResponseText>
                            </postProcessing>
                            <applicationProperties type="com.fnfr.itest.platform2.shared.documents.ntaf.NtafTransferableDocumentObject" action="Custom" subharness="http://spirent.com/NTAF/harness/iTest/LandslideRest/Main" harness="http://spirent.com/NTAF/harness/iTest/LandslideRest/Main" harnessName="http://spirent.com/NTAF/harness/iTest/LandslideRest/Main" requestMethod.inherit="false" dataType="xml" dataType.inherit="false" rawResponse="true" rawResponse.inherit="false" url="libraries/[library_id]/dmfs/[dmf_name]?as=xml" url.inherit="false"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="9a2ee916-04bf-47a0-9859-96df44c35ef3" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Modify the sample DMF with the appropriate update</body>
                    </command>
                    <nestedSteps>
                        <item guid="31169968-3df8-46b4-b78d-01c7b4b72a32" action="comment" useFieldsInCommand="false">
                            <command>
                                <body>Append the DMF name with current date time to create a unique name</body>
                            </command>
                            <nestedSteps>
                                <item guid="22b5d162-a0c2-4a1a-8b9d-99ae82f8ceeb" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>import datetime</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="06a166df-b3cf-48be-bf09-240a0a4841ee" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>current_time = datetime.datetime.now()</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="bf46b464-2a2e-4185-aef8-446ad1d11086" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>output_time = current_time.strftime(&quot;%Y-%m-%d-%H-%M&quot;)</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="009e09dc-659d-46ec-9cc2-019219285b3a" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>new_dmf_name = f&quot;{dmf_name}-{output_time}&quot;</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="b074d375-2d58-4bb1-adf2-21b165e66688" action="comment" useFieldsInCommand="false">
                            <command>
                                <body>Update the required fields</body>
                            </command>
                            <nestedSteps>
                                <item guid="4a120cd1-29a0-474c-9c54-e719dd68fe68" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>import re</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="073cd521-b124-4ef0-b42d-d9419f810abd" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>field_pattern = r&quot;&quot;&quot;{}\\s?=\\s?[&apos;&quot;](.+?)[&apos;&quot;]&quot;&quot;&quot;</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="77971da4-949f-4538-8ef4-cc1e839c20fd" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>dmf_body = re.sub(field_pattern.format(&apos;tr&apos;), f&apos;tr=&quot;{new_tr_val}&quot;&apos;, dmf_body)</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="e40a00aa-1b67-4994-afd0-14156a4e5514" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>dmf_body = re.sub(field_pattern.format(&apos;tt&apos;), f&apos;tt=&quot;{new_tt_val}&quot;&apos;, dmf_body)</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="8dd79966-ece8-4266-b450-77df321b0896" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>dmf_body = re.sub(field_pattern.format(&apos;uid&apos;), f&apos;uid=&quot;{user_lib_id}&quot;&apos;, dmf_body)</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="d6d7956a-3ee8-4ff0-af5e-eba31e35bc1e" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>dmf_body = re.sub(field_pattern.format(&apos;name&apos;), f&apos;name=&quot;{new_dmf_name}&quot;&apos;, dmf_body)</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="5d2f5d45-852e-498b-a32e-1062da18d264" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Create new DMF in the [user] library</body>
                    </command>
                    <nestedSteps>
                        <item guid="67458ba9-6558-4b81-91e7-1992ed93fb34" action="Custom" session="s1">
                            <command>
                                <body>-requestMethod POST -dataType xml -requestBody [dmf_body] -rawResponse true -url libraries/[user_lib_id]/dmfs</body>
                            </command>
                            <postProcessing>
                                <analysisRules>
                                    <item>
                                        <extractorInfo extractorType="query">
                                            <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                <query>success()</query>
                                            </extractorProperties>
                                        </extractorInfo>
                                        <processorInfo ruleType="assert">
                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                <expression>value == &quot;true&quot;</expression>
                                                <actionsWhenTrue>
                                                    <item actionId="SkipRemainingRules">
                                                        <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                    </item>
                                                </actionsWhenTrue>
                                            </ruleProperties>
                                        </processorInfo>
                                    </item>
                                    <item>
                                        <extractorInfo extractorType="query">
                                            <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                <query>mapped/Json/reason</query>
                                            </extractorProperties>
                                        </extractorInfo>
                                        <processorInfo ruleType="assert">
                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                <expression>True</expression>
                                                <actionsWhenTrue>
                                                    <item actionId="Eval">
                                                        <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                                            <statement>new_dmf_name = value</statement>
                                                        </actionProperties>
                                                    </item>
                                                    <item actionId="FailTest">
                                                        <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                    </item>
                                                </actionsWhenTrue>
                                            </ruleProperties>
                                        </processorInfo>
                                    </item>
                                </analysisRules>
                            </postProcessing>
                            <applicationProperties type="com.fnfr.itest.platform2.shared.documents.ntaf.NtafTransferableDocumentObject" action="Custom" subharness="http://spirent.com/NTAF/harness/iTest/LandslideRest/Main" harness="http://spirent.com/NTAF/harness/iTest/LandslideRest/Main" harnessName="http://spirent.com/NTAF/harness/iTest/LandslideRest/Main" requestMethod="POST" requestMethod.inherit="false" dataType="xml" dataType.inherit="false" requestBody="[dmf_body]" requestBody.inherit="false" rawResponse="true" rawResponse.inherit="false" url="libraries/[user_lib_id]/dmfs" url.inherit="false"/>
                        </item>
                        <item guid="178c936f-5a90-466b-aaa0-305a969c14b2" action="return">
                            <command>
                                <body>[new_dmf_name]</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
            </steps>
            <arguments>
                <item name="library_id"/>
                <item name="new_tt_val"/>
                <item name="user_lib_id"/>
                <item name="dmf_name"/>
                <item name="new_tr_val"/>
            </arguments>
        </item>
    </procedures>
</testCase>
