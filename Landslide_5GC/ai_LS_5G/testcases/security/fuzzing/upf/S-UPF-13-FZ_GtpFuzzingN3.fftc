                                <body>Validate KPIs</body>
                            </command>
                            <nestedSteps>
                                <item guid="41a0979f-52ab-4a50-af04-5ab59a204251" action="call" useFieldsInCommand="false">
                                    <command>
                                        <body>validate_KPIs(measurement_favorites=measurement_favorites, t_load=session_capacity, fuzz_rate=fuzzing_rate, running_id=running_nodal_id, is_b2b=is_b2b)</body>
                                    </command>
                                    <postProcessing>
                                        <analysisRules>
                                            <item>
                                                <extractorInfo extractorType="query">
                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                        <query>result()</query>
                                                    </extractorProperties>
                                                </extractorInfo>
                                                <processorInfo ruleType="assert">
