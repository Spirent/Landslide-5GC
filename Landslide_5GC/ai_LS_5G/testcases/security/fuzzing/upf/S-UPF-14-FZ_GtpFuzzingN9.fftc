<?xml version="1.0"?>
<testCase version="25.4.0.202512130118">
    <general>
        <documentation>S-UPF-14-FZ: Robustness and Fuzz Testing (GTP-U) - Security Testing</documentation>
        <tags>S-UPF-14-FZ</tags>
        <notes masked="true"></notes>
