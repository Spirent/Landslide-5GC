                        <body>Information:The number of data transactions (dataTrans): [data_trans] data transactions.</body>
                    </command>
                    <applicationProperties type="com.fnfr.svt.execution.builtin.exec.MessagePropertyGroup">
                        <message inherit="false">The number of data transactions (dataTrans): [data_trans] data transactions.</message>
                    </applicationProperties>
                </item>
                <item guid="02ea10ca-28fb-4233-a222-dc90ccb53d92" action="message" useFieldsInCommand="false">
                    <command>
                        <body>Information:The number of data transactions rate (dataTps): [data_tps] data transactions per second.</body>
                    </command>
                    <applicationProperties type="com.fnfr.svt.execution.builtin.exec.MessagePropertyGroup">
                        <message inherit="false">The number of data transactions rate (dataTps): [data_tps] data transactions per second.</message>
                    </applicationProperties>
                </item>
                <item guid="24b5cceb-91c0-435d-b4b5-60364da2eb6f" action="call" useFieldsInCommand="false">
                    <command>
                        <body>project://ai_LS_5G/utility_library/utils.fftc#insert_devider_string(char=&apos;=&apos;, length=&apos;80&apos;)</body>
                    </command>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
            </steps>
            <arguments>
                <item name="t_rate">
                    <isMandatory>true</isMandatory>
                </item>
                <item name="fuzz_prob"/>
