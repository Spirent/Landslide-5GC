                <item guid="2179147b-0cb9-41bc-ad5c-73d7e0cc0f68" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Calculate if needed</body>
                    </command>
                    <nestedSteps>
                        <item guid="1eacf24d-449a-4640-ba4d-ba65619799f8" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>delta = math.ceil(t_load * 3 / 100)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="b1b9aa3d-cc5d-495c-94c0-d92112a1d4c9" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>fuzz_load = int(int(t_load)/int(fuzz_rate))</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="cadf0008-0f33-43ad-b437-de0d8a252136" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>value1_kpi_value = error_indications_received</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="f15a11b9-0d57-4035-89b3-d14b302576b1" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>lower_bound = math.floor(fuzz_load - delta)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="e987a118-cc25-46d1-b6eb-ee7ea8814c1d" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>upper_bound = math.ceil(fuzz_load + delta)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="f311234e-e8a5-44b4-b6a4-cb4d3b6a9934" action="if" useFieldsInCommand="false">
                            <command>
                                <body>upper_bound &gt; t_load:</body>
                            </command>
                            <nestedSteps>
                                <item guid="93b6581f-823a-4198-bdb1-57a7c4bc2b91" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>upper_bound = t_load</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="07ceaf76-cd3f-4635-b8e5-5d9516b4903c" action="if" useFieldsInCommand="false">
                            <command>
                                <body>lower_bound &lt; 0:</body>
                            </command>
                            <nestedSteps>
                                <item guid="93b6581f-823a-4198-bdb1-57a7c4bc2b91" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>lower_bound = 0</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
