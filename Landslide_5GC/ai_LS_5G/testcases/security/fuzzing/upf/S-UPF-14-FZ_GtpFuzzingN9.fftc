                <item guid="2b6c2f5c-7726-43c0-bfda-e65d4693d0db" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Delete the DMF file </body>
                    </command>
                    <nestedSteps>
                        <item guid="d4094f4b-a903-45c3-bb87-dbe0d2d6e273" action="if" useFieldsInCommand="false">
                            <command>
                                <body>int(data_trans) !=int(default_data_trans) or int(data_tps) !=int(default_data_tps):</body>
                            </command>
                            <nestedSteps>
                                <item guid="1bc0cc49-b1b3-4a98-a6c0-bb1f90d50b4a" action="Custom" session="s1">
                                    <command>
                                        <body>-requestMethod DELETE -dataType xml -rawResponse true -url libraries/[user_lib_id]/dmfs/[dmf_name_file]</body>
                                    </command>
                                    <postProcessing>
                                        <analysisRules>
                                            <item>
                                                <extractorInfo extractorType="query">
                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                        <query>success()</query>
                                                    </extractorProperties>
                                                </extractorInfo>
                                                <processorInfo ruleType="assert">
                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                        <expression>value == &quot;true&quot;</expression>
                                                        <actionsWhenTrue>
                                                            <item actionId="SkipRemainingRules">
                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                            </item>
                                                        </actionsWhenTrue>
                                                    </ruleProperties>
                                                </processorInfo>
                                            </item>
                                            <item>
                                                <extractorInfo extractorType="query">
                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                        <query>mapped/Json/reason</query>
                                                    </extractorProperties>
                                                </extractorInfo>
                                                <processorInfo ruleType="assert">
                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                        <expression>True</expression>
                                                        <actionsWhenTrue>
                                                            <item actionId="DeclareExecutionIssue">
                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.ExecutionIssuePropertyGroup" severity="Warning">
                                                                    <message>{value}</message>
                                                                </actionProperties>
                                                            </item>
                                                        </actionsWhenTrue>
                                                    </ruleProperties>
                                                </processorInfo>
                                            </item>
                                        </analysisRules>
                                        <storeResponseAt>dmf_body</storeResponseAt>
                                        <storeResponseText>true</storeResponseText>
                                    </postProcessing>
                                    <applicationProperties type="com.fnfr.itest.platform2.shared.documents.ntaf.NtafTransferableDocumentObject" action="Custom" subharness="http://spirent.com/NTAF/harness/iTest/LandslideRest/Main" harness="http://spirent.com/NTAF/harness/iTest/LandslideRest/Main" harnessName="http://spirent.com/NTAF/harness/iTest/LandslideRest/Main" requestMethod="DELETE" requestMethod.inherit="false" dataType="xml" dataType.inherit="false" rawResponse="true" rawResponse.inherit="false" url="libraries/[user_lib_id]/dmfs/[dmf_name_file]" url.inherit="false"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="e468b430-3a99-49a9-a7fe-4f5eb28a65d1" action="return">
                    <command>
                        <body>[response]</body>
                    </command>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
            </steps>
            <arguments>
                <item name="run_data">
                    <isMandatory>true</isMandatory>
                </item>
                <item name="t_load"/>
                <item name="t_rate"/>
                <item name="running_node_id"/>
                <item name="is_b2b">
                    <defaultValue>true</defaultValue>
                    <isMandatory>true</isMandatory>
                </item>
                <item name="timeout">
                    <defaultValue>180</defaultValue>
                </item>
            </arguments>
            <response>{}</response>
        </item>
