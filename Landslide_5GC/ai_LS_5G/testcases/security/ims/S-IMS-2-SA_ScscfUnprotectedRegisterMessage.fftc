        <item name="extract_pcap_kpis" isPublic="true">
            <steps>
                <item guid="e4b0f202-12ad-46a6-8b0d-ab7370876af5" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Valide Nodal pcaps</body>
                    </command>
                    <nestedSteps>
                        <item guid="4106e215-7e92-4561-b9dd-bb30c2d875eb" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>sip_phy = param(&apos;LS_Nodal_favorite_params/TS1/ts0/tc0/SipPCSCFAddr/phy&apos;, &apos;eth2&apos;);print(sip_phy)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="fc4d360c-8b04-4d6f-b334-873a8e1a0ca0" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>sip_ip = param(&apos;LS_Nodal_favorite_params/TS1/ts0/tc0/SipPCSCFAddr/ip&apos;, &apos;10.202.100.1&apos;);print(sip_ip)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="91a9184b-0146-4f29-8872-00f751e615ae" action="for" useFieldsInCommand="false">
                            <command>
                                <body>i in range(0, len(nodal_pcaps)):</body>
                            </command>
                            <nestedSteps>
                                <item guid="c431aed5-7c32-4d65-8b2e-937b87814bf8" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>pcap = nodal_pcaps[i]</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="114fa691-8c9e-41dc-942c-3574e30b5aa5" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>pcap_name = nodal_file_names[i]</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="5902846f-c494-482e-b952-e3aaafa2b015" action="call" useFieldsInCommand="false">
                                    <command>
                                        <body>project://ai_LS_5G/utility_library/utils.fftc#extract_the_filename_from_result_link(file_name=pcap_name)</body>
                                    </command>
                                    <postProcessing>
                                        <storeResponseAt>pcap_name</storeResponseAt>
                                        <storeResponseText>true</storeResponseText>
                                    </postProcessing>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="a8e3b082-5dd8-4cc3-a928-c70a79d7fb71" action="if" useFieldsInCommand="false">
                                    <command>
                                        <body>sip_phy in pcap_name:</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="c8d79ab3-37ef-474e-9efd-29528d1ecbb8" action="comment" useFieldsInCommand="false">
                                            <command>
                                                <body>SIP Interface</body>
                                            </command>
                                            <nestedSteps>
                                                <item guid="7815c675-18d7-4943-a1c2-a337ec861645" action="comment" useFieldsInCommand="false" skippReporting="false">
