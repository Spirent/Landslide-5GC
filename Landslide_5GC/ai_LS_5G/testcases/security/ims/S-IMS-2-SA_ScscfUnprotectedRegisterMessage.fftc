                                                        <body>interface_name = &quot;SIP Interface&quot;</body>
                                                    </command>
                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                </item>
                                                <item guid="abc7c4f2-63c6-4ba4-9a8e-afa8f36e1d65" action="call" useFieldsInCommand="false">
                                                    <command>
                                                        <body>project://ai_LS_5G/utility_library/utils.fftc#extract_the_filename_from_result_link(file_name=pcap_name)</body>
