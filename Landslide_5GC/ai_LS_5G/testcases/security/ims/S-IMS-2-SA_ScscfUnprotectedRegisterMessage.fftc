                                                </item>
                                                <item guid="088a6a81-ab53-4b9e-8d4e-541e35a6369f" action="eval" useFieldsInCommand="false">
                                                    <command>
                                                        <body>print(pcap)</body>
                                                    </command>
                                                    <postProcessing>
                                                        <analysisRules>
