                                                                    <command>
                                                                        <body>The first register process simulates the initial register in iteration 1</body>
                                                                    </command>
                                                                    <nestedSteps>
                                                                        <item guid="25b100a3-2921-4f34-8953-e57e80141c96" action="command" session="s4">
