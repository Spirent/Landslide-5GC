                            </command>
                            <nestedSteps>
                                <item guid="0818082f-2f8c-406f-a74a-4451cdee1cdc" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>print(response)</body>
                                    </command>
                                    <postProcessing>
                                        <analysisRules>
                                            <item>
                                                <extractorInfo extractorType="query">
                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                        <query>result()</query>
                                                    </extractorProperties>
                                                </extractorInfo>
                                                <processorInfo ruleType="assert">
                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                        <expression>value == &quot;PASS&quot;</expression>
                                                        <actionsWhenTrue>
                                                            <item actionId="DeclareExecutionIssue">
                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.ExecutionIssuePropertyGroup" severity="OK">
                                                                    <message>All acceptance criteria PASSED</message>
                                                                </actionProperties>
                                                            </item>
                                                        </actionsWhenTrue>
                                                        <actionsWhenFalse>
                                                            <item actionId="FailTestIfPassing">
                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                            </item>
                                                        </actionsWhenFalse>
                                                    </ruleProperties>
                                                </processorInfo>
                                            </item>
                                        </analysisRules>
                                    </postProcessing>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="cf056ea6-36e7-4213-86f6-b6300a503419" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Add Favorites to response</body>
                    </command>
                    <nestedSteps>
                        <item guid="ecc371f4-4bf1-4651-928c-22127a25ee07" action="add_favorites_to_KPIs" session="s1" useFieldsInCommand="false">
                            <command>
                                <body>(running_id=&apos;&apos;, favorites=measurement_favorites, response=response, skip_duplicate=&apos;false&apos;)</body>
                            </command>
                            <postProcessing>
                                <storeResponseAt>response</storeResponseAt>
                                <storeResponseText>true</storeResponseText>
                            </postProcessing>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="cccbadc8-44c6-4a30-9344-74628031b278" action="return">
                    <command>
                        <body>[response]</body>
                    </command>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
            </steps>
            <arguments>
                <item name="measurement_favorites">
                    <isMandatory>true</isMandatory>
                </item>
                <item name="running_id"/>
                <item name="measurement_info"/>
                <item name="is_b2b"/>
            </arguments>
        </item>
        <item name="extract_pcap_with_valid_keys" isPublic="true">
            <steps>
                <item guid="046747ab-834f-42aa-b325-0df614148861" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Valide Nodal pcaps</body>
                    </command>
                    <nestedSteps>
                        <item guid="0f8f296b-7fdf-46a5-8568-abe9c115e708" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>gm_phy = param(&apos;LS_Nodal_favorite_params/TS1/ts0/tc0/MobileNodeAddr/phy&apos;, &apos;eth2&apos;); print(gm_phy);</body>
                            </command>
                            <eventHandlers>
                                <item name="OnInterpreterError">
                                    <item actionId="Eval">
                                        <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                            <statement>n20_phy = &quot;eth2&quot;</statement>
                                        </actionProperties>
                                    </item>
                                </item>
                            </eventHandlers>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="d362944e-2864-4ee1-8cc3-715f6f66d61a" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>gm_node_ip = param(&apos;LS_Nodal_favorite_params/TS1/ts0/tc0/MobileNodeAddr/ip&apos;, &apos;10.202.1.1&apos;); print(gm_node_ip);</body>
                            </command>
                            <eventHandlers>
                                <item name="OnInterpreterError">
                                    <item actionId="Eval">
                                        <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                            <statement>n20_phy = &quot;eth2&quot;</statement>
                                        </actionProperties>
                                    </item>
                                </item>
                            </eventHandlers>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="691d2d8d-f207-4f8b-b50e-bb8a96ddac70" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>gm_user_node_ip = param(&apos;SUT/nodal_ts0_tc0/SipPCSCFAddr/name&apos;, &apos;10.202.100.1&apos;); print(sip_sut_ip);</body>
                            </command>
                            <eventHandlers>
                                <item name="OnInterpreterError">
                                    <item actionId="Eval">
                                        <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                            <statement>n20_phy = &quot;eth2&quot;</statement>
                                        </actionProperties>
                                    </item>
                                </item>
                            </eventHandlers>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="b93a6f59-7da9-445b-bcfd-449563c0362d" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>pcap_exist = False</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="054fbf7a-cef3-438a-8219-10b03ab753cf" action="comment" useFieldsInCommand="false">
                            <command>
                                <body>Verify pcap acceptance check</body>
                            </command>
                            <nestedSteps>
                                <item guid="5ca1964c-4718-42de-808f-3fa5e79f99a0" action="for" useFieldsInCommand="false">
                                    <command>
                                        <body>i in range(0, len(nodal_pcaps)):</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="b344cf07-3f41-4d83-b715-56d921a0fa71" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>pcap = nodal_pcaps[i]</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="135c4fd8-decd-4d3e-b9d5-d80aff67c9b0" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>pcap_name = nodal_file_names[i]</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="45e23a3c-bc49-4c0e-9d8b-997eb22817c9" action="if" useFieldsInCommand="false">
                                            <command>
                                                <body>gm_phy in pcap_name:</body>
                                            </command>
                                            <nestedSteps>
                                                <item guid="2ad3d068-8240-4ee3-8553-3742bb5d16ce" action="comment" useFieldsInCommand="false">
                                                    <command>
                                                        <body>Validate</body>
                                                    </command>
                                                    <nestedSteps>
                                                        <item guid="fd31883a-6ffb-4e65-996c-3d6109d5f7d5" action="eval" useFieldsInCommand="false">
                                                            <command>
                                                                <body>pcap_exist = True</body>
                                                            </command>
                                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                        </item>
                                                        <item guid="3cbe218d-b8dd-4d57-a580-ad1663f88961" action="eval" useFieldsInCommand="false">
                                                            <command>
                                                                <body>print(pcap)</body>
                                                            </command>
                                                            <postProcessing>
                                                                <analysisRules>
                                                                    <item>
                                                                        <extractorInfo extractorType="query">
                                                                            <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                                                <query>isEmpty</query>
                                                                            </extractorProperties>
                                                                        </extractorInfo>
                                                                        <processorInfo ruleType="message">
                                                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.MessageProcessorPropertyGroup" severity="Information">
                                                                                <message>Analyzing data in pcap file: [pcap_name]</message>
                                                                                <tag sub="false" defaultValue=""/>
                                                                            </ruleProperties>
                                                                        </processorInfo>
                                                                    </item>
                                                                </analysisRules>
                                                            </postProcessing>
                                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                        </item>
                                                        <item guid="08865bd3-d572-4407-94d7-0954188e46e1" action="command" session="s4">
                                                            <command>
                                                                <body>query load &quot;[pcap]&quot;</body>
                                                            </command>
                                                            <postProcessing>
                                                                <analysisRules>
                                                                    <item>
                                                                        <extractorInfo extractorType="query">
                                                                            <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                                                <query>responseLine()</query>
                                                                            </extractorProperties>
                                                                        </extractorInfo>
                                                                        <processorInfo ruleType="assert">
                                                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                                                <expression>value == &quot;done&quot;</expression>
                                                                                <actionsWhenFalse>
                                                                                    <item actionId="FailTest">
                                                                                        <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                                    </item>
                                                                                    <item actionId="DeclareExecutionIssue">
                                                                                        <actionProperties type="com.fnfr.svt.execution.builtin.actions.ExecutionIssuePropertyGroup">
                                                                                            <message>Can&apos;t load [pcap]</message>
                                                                                        </actionProperties>
                                                                                    </item>
                                                                                    <item actionId="ExitProcedure">
                                                                                        <actionProperties type="com.fnfr.svt.execution.builtin.actions.ExitProcedurePropertyGroup"/>
                                                                                    </item>
                                                                                </actionsWhenFalse>
                                                                            </ruleProperties>
                                                                        </processorInfo>
                                                                    </item>
                                                                </analysisRules>
                                                            </postProcessing>
                                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                        </item>
                                                        <item guid="ccdf345b-dd27-4522-8474-5444c2ac42df" action="eval" useFieldsInCommand="false">
                                                            <command>
                                                                <body>gset(&apos;pcap&apos;,pcap)</body>
                                                            </command>
                                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                        </item>
                                                        <item guid="e6bdc25e-8355-4bfb-a748-91f1688221d0" action="eval" useFieldsInCommand="false">
                                                            <command>
                                                                <body>gset(&apos;pcap_name&apos;,pcap_name)</body>
                                                            </command>
                                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                        </item>
                                                        <item guid="4de76181-aba3-4e3e-847d-cb7ddc9950b8" action="comment" useFieldsInCommand="false">
                                                            <command>
                                                                <body>Find all ESP packets (expected = 13 packets as message flow)</body>
                                                            </command>
                                                            <nestedSteps>
                                                                <item guid="d1ddd104-ec6f-451c-a606-28ba3820c468" action="eval" useFieldsInCommand="false">
                                                                    <command>
                                                                        <body>tag_key = &quot;ESP packets&quot;</body>
                                                                    </command>
                                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                </item>
                                                                <item guid="f208e34b-4e9d-4199-876b-4bcad1b801a4" action="command" session="s4">
                                                                    <command>
                                                                        <body>query filter set &quot;sip || esp and !tcp&quot;</body>
                                                                    </command>
                                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                </item>
                                                                <item guid="21d5f194-c448-498e-9a3b-d8bc315fbdd8" action="command" session="s4">
                                                                    <command>
                                                                        <body>query packets</body>
                                                                    </command>
                                                                    <postProcessing>
                                                                        <analysisRules>
                                                                            <item>
                                                                                <extractorInfo extractorType="query">
                                                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                                                        <query>success()</query>
                                                                                    </extractorProperties>
                                                                                </extractorInfo>
                                                                                <processorInfo ruleType="assert">
                                                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                                                        <expression>value == &quot;true&quot;</expression>
                                                                                        <actionsWhenFalse>
                                                                                            <item actionId="FailTest">
                                                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                                            </item>
                                                                                            <item actionId="DeclareExecutionIssue">
                                                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.ExecutionIssuePropertyGroup">
                                                                                                    <message>Expected ESP Decrypted Packet does not find.</message>
                                                                                                </actionProperties>
                                                                                            </item>
                                                                                            <item actionId="ExitProcedure">
                                                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.ExitProcedurePropertyGroup"/>
                                                                                            </item>
                                                                                            <item actionId="SkipRemainingRules">
                                                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                                            </item>
                                                                                        </actionsWhenFalse>
                                                                                    </ruleProperties>
                                                                                </processorInfo>
                                                                            </item>
                                                                            <item>
                                                                                <extractorInfo extractorType="query">
                                                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                                                        <query>rowCount()</query>
                                                                                    </extractorProperties>
                                                                                </extractorInfo>
                                                                                <processorInfo ruleType="assert">
                                                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                                                        <expression>int(value) == 13</expression>
                                                                                        <actionsWhenFalse>
                                                                                            <item actionId="FailTest">
                                                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                                            </item>
                                                                                            <item actionId="DeclareExecutionIssue">
                                                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.ExecutionIssuePropertyGroup">
                                                                                                    <message>&quot;[tag_key]&quot; found {value} in pcap file. Expected: = 13</message>
                                                                                                </actionProperties>
                                                                                            </item>
                                                                                            <item actionId="ExitProcedure">
                                                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.ExitProcedurePropertyGroup"/>
                                                                                            </item>
                                                                                            <item actionId="SkipRemainingRules">
                                                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                                            </item>
                                                                                        </actionsWhenFalse>
                                                                                    </ruleProperties>
                                                                                </processorInfo>
                                                                            </item>
                                                                            <item>
                                                                                <extractorInfo extractorType="query">
                                                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                                                        <query>messages/item/id</query>
                                                                                    </extractorProperties>
                                                                                </extractorInfo>
                                                                                <processorInfo ruleType="store">
                                                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                                                                        <storageLocation>esp_packets_id_list</storageLocation>
                                                                                        <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                                                                        <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                                                                        <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                                                                    </ruleProperties>
                                                                                </processorInfo>
                                                                            </item>
                                                                        </analysisRules>
                                                                    </postProcessing>
                                                                    <eventHandlers>
                                                                        <item name="OnWiresharkCommandFailed">
                                                                            <item actionId="Eval">
                                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                                                                    <statement>id = &quot;&quot;</statement>
                                                                                </actionProperties>
                                                                            </item>
                                                                        </item>
                                                                    </eventHandlers>
                                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                </item>
                                                                <item guid="b9d34238-4d83-4d97-8cc9-01596a598ccd" action="eval" useFieldsInCommand="false">
                                                                    <command>
                                                                        <body>gset(&apos;esp_packets_id_list&apos;, esp_packets_id_list)</body>
                                                                    </command>
                                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                </item>
                                                                <item guid="18916e16-6301-4593-b9dd-1037f2fb1b30" action="comment" useFieldsInCommand="false">
                                                                    <command>
                                                                        <body>Validate &quot;ESP packets are Decrypted Successfull&quot;:</body>
                                                                    </command>
                                                                    <nestedSteps>
                                                                        <item guid="b2620dfa-146b-4e25-b2ea-a98c38b4ba66" action="message" useFieldsInCommand="false">
                                                                            <command>
                                                                                <body>Information:Validate &quot;ESP packets are Decrypted Successfull&quot;:</body>
                                                                            </command>
                                                                            <applicationProperties type="com.fnfr.svt.execution.builtin.exec.MessagePropertyGroup">
                                                                                <message inherit="false">Validate &quot;ESP packets are Decrypted Successfull&quot;:</message>
                                                                            </applicationProperties>
                                                                        </item>
                                                                        <item guid="47765ccf-cae0-44fc-a5ff-cb247574e925" action="eval" useFieldsInCommand="false">
                                                                            <command>
                                                                                <body>is_decrypted = &quot;true&quot;</body>
                                                                            </command>
                                                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                        </item>
                                                                        <item guid="6643c465-447a-495e-9af7-65115ff06c16" action="for" useFieldsInCommand="false">
                                                                            <command>
                                                                                <body>id in esp_packets_id_list:</body>
                                                                            </command>
                                                                            <nestedSteps>
                                                                                <item guid="24832ae6-deac-4747-922a-d556b4df15fc" action="command" session="s4">
                                                                                    <command>
                                                                                        <body>query details [id] pdml </body>
                                                                                    </command>
                                                                                    <postProcessing>
                                                                                        <analysisRules>
                                                                                            <item>
                                                                                                <extractorInfo extractorType="query">
                                                                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                                                                        <query>success()</query>
                                                                                                    </extractorProperties>
                                                                                                </extractorInfo>
                                                                                                <processorInfo ruleType="assert">
                                                                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                                                                        <expression>value == &quot;true&quot;</expression>
                                                                                                        <actionsWhenFalse>
                                                                                                            <item actionId="DeclareExecutionIssue">
                                                                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.ExecutionIssuePropertyGroup">
                                                                                                                    <message>Cannot query packet [id]</message>
                                                                                                                </actionProperties>
                                                                                                            </item>
                                                                                                            <item actionId="FailTest">
                                                                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                                                            </item>
                                                                                                            <item actionId="ExitProcedure">
                                                                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.ExitProcedurePropertyGroup"/>
                                                                                                            </item>
                                                                                                            <item actionId="SkipRemainingRules">
                                                                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                                                            </item>
                                                                                                        </actionsWhenFalse>
                                                                                                    </ruleProperties>
                                                                                                </processorInfo>
                                                                                            </item>
                                                                                            <item>
                                                                                                <extractorInfo extractorType="query">
                                                                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                                                                        <query>boolean(//field[@name=&quot;sip.Status-Line&quot; or @name=&quot;sip.Request-Line&quot;]/@show)</query>
                                                                                                    </extractorProperties>
                                                                                                </extractorInfo>
                                                                                                <processorInfo ruleType="assert">
                                                                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                                                                        <expression>value == &quot;true&quot;</expression>
                                                                                                        <actionsWhenTrue>
                                                                                                            <item actionId="PassTestIfNotAlreadyFailed">
                                                                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                                                            </item>
                                                                                                        </actionsWhenTrue>
                                                                                                        <actionsWhenFalse>
                                                                                                            <item actionId="DeclareExecutionIssue">
                                                                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.ExecutionIssuePropertyGroup" severity="Warning">
                                                                                                                    <message>   ESP packet id &quot;[id]&quot; is NOT decrypted successfully</message>
                                                                                                                </actionProperties>
                                                                                                            </item>
                                                                                                            <item actionId="FailTest">
                                                                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                                                            </item>
                                                                                                            <item actionId="Eval">
                                                                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                                                                                                    <statement>is_decrypted = &quot;false&quot;</statement>
                                                                                                                </actionProperties>
                                                                                                            </item>
                                                                                                            <item actionId="SkipRemainingRules">
                                                                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                                                            </item>
                                                                                                        </actionsWhenFalse>
                                                                                                    </ruleProperties>
                                                                                                </processorInfo>
                                                                                            </item>
                                                                                            <item>
                                                                                                <extractorInfo extractorType="query">
                                                                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                                                                        <query>//field[@name=&quot;sip.Status-Line&quot; or @name=&quot;sip.Request-Line&quot;]/@show</query>
                                                                                                    </extractorProperties>
                                                                                                </extractorInfo>
                                                                                                <processorInfo ruleType="store">
                                                                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                                                                                        <storageLocation>sip_decrypted_message</storageLocation>
                                                                                                        <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                                                                                        <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                                                                                        <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                                                                                    </ruleProperties>
                                                                                                </processorInfo>
                                                                                            </item>
                                                                                            <item>
                                                                                                <extractorInfo extractorType="none">
                                                                                                    <extractorProperties type="com.fnfr.svt.documents.EmptyExtractorPropertyGroup"/>
                                                                                                </extractorInfo>
                                                                                                <processorInfo ruleType="message">
                                                                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.MessageProcessorPropertyGroup" severity="OK">
                                                                                                        <message>    Packet No.[id] decrypted: &quot;[sip_decrypted_message]&quot;</message>
                                                                                                        <tag sub="false" defaultValue=""/>
                                                                                                    </ruleProperties>
                                                                                                </processorInfo>
                                                                                            </item>
                                                                                        </analysisRules>
                                                                                    </postProcessing>
                                                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                                </item>
                                                                            </nestedSteps>
                                                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                        </item>
                                                                        <item guid="6bb73463-6c04-4986-a23b-7b01a452b606" action="if" useFieldsInCommand="false">
                                                                            <command>
                                                                                <body>is_decrypted == &quot;true&quot;:</body>
                                                                            </command>
                                                                            <nestedSteps>
                                                                                <item guid="7b0c122e-adc8-47cb-9894-77bc85a4e600" action="message" useFieldsInCommand="false">
                                                                                    <command>
                                                                                        <body>OK:The signaling packets are encrypted, and the transported IMS signaling between the UE and IMS Node is protected</body>
                                                                                    </command>
                                                                                    <applicationProperties type="com.fnfr.svt.execution.builtin.exec.MessagePropertyGroup">
                                                                                        <severity inherit="false">OK</severity>
                                                                                        <message inherit="false">The signaling packets are encrypted, and the transported IMS signaling between the UE and IMS Node is protected</message>
                                                                                    </applicationProperties>
                                                                                </item>
                                                                            </nestedSteps>
                                                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
