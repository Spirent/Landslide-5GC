                                </item>
                                <item guid="5597cbd5-473f-4355-872c-79fca57c607b" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>print(authentication_key)</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="08bd10cd-7aa8-4b2d-947f-db1bc4ff38f2" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>print(valid_key);</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="40816719-12d8-4dc8-a66e-4cd37ebcf62e" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>print(invalid_key);</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
