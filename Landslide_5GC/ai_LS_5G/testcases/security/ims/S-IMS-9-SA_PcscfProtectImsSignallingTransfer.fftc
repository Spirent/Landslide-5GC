                                </item>
                                <item guid="eac42706-1b9b-4390-a9de-395e05f773d6" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>print(spi_1)</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="7aab717a-d9af-4f38-ba4d-0aa73923cea1" action="eval" useFieldsInCommand="false">
