                                                <query>//esp_encryption_key_2</query>
                                            </extractorProperties>
                                        </extractorInfo>
                                        <processorInfo ruleType="store">
                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                                <storageLocation>esp_encryption_key_2</storageLocation>
                                                <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                                <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                                <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                            </ruleProperties>
                                        </processorInfo>
                                    </item>
                                </analysisRules>
                                <storeResponseAt>esp_encryption_keypairs</storeResponseAt>
                                <storeResponseText>true</storeResponseText>
                            </postProcessing>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="bb49b886-b566-486f-8b3a-8c5163ddbc24" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Define wireshark display filter command for the ESP packet decryption</body>
                    </command>
                    <nestedSteps>
                        <item guid="1c4c3922-d626-4ad7-9e49-0f4c8e86e0de" action="if" useFieldsInCommand="false">
                            <command>
                                <body>esp_encryption_key_1 and esp_encryption_key_2:</body>
                            </command>
                            <nestedSteps>
                                <item guid="87d1e6b5-3e22-4b18-9df6-7af05bf3aed9" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>Define pattern to get encryption, spi, authentication data </body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="38deaf41-8e90-4067-b3b8-d30534fa5549" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>spi_pattern = re.compile(r&quot;SPI: (\\S+)&quot;)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="74808864-70e5-405a-b79f-53677b89596c" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>encryption_key_pattern = re.compile(r&quot;Encryption[\\s_]Key: (0x[\\da-fA-F]+)&quot;)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="1f559ac0-5660-4011-8aa8-8a0a0dafddb0" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>authentication_key_pattern = re.compile(r&quot;Authentication[\\s_]Key: (0x[\\da-fA-F]+)&quot;)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="e2e36609-5d76-42be-adad-cc4d5350b795" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>Get encryption name</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="a9e757d1-ce24-40f7-87f3-14544fc3ea8c" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>encryption = param(&apos;LS_Nodal_favorite_params/TS1/ts0/tc0/UeEncryptionAlgorithm&apos;,&apos;NULL&apos;); print(encryption);</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="49b3fb3b-13d0-4a0c-9aac-b64f683046a8" action="if" useFieldsInCommand="false">
                                            <command>
                                                <body>encryption in [&quot;DES_EDE3_CBC&quot;,&quot;DES-CBC [RFC2405]&quot;]:</body>
                                            </command>
                                            <nestedSteps>
                                                <item guid="5f6f3843-55a6-4b1d-92ba-b5d8f0c1c60f" action="eval" useFieldsInCommand="false">
                                                    <command>
                                                        <body>encryption = &quot;DES-CBC [RFC2405]&quot;</body>
                                                    </command>
                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                </item>
                                            </nestedSteps>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="89600a8d-00cd-407c-a792-4878859c4348" action="elif" useFieldsInCommand="false">
                                            <command>
                                                <body>encryption in [&quot;AES_CBC&quot;,&quot;AES-CBC [RFC3602]&quot;]:</body>
                                            </command>
                                            <nestedSteps>
                                                <item guid="5f6f3843-55a6-4b1d-92ba-b5d8f0c1c60f" action="eval" useFieldsInCommand="false">
                                                    <command>
                                                        <body>encryption = &quot;AES-CBC [RFC3602]&quot;</body>
                                                    </command>
                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                </item>
                                            </nestedSteps>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="cf0f2828-b136-4f48-af8e-9f80061db4ac" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>Get authentication name</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="d6a863cd-e313-4304-9b69-c424227d5255" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>authentication = param(&apos;LS_Nodal_favorite_params/TS1/ts0/tc0/UeAuthAlgorithm&apos;,&apos;0&apos;); print(authentication);</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="9a6198d9-3da1-4817-b0b8-2f665cd445a2" action="if" useFieldsInCommand="false">
                                            <command>
                                                <body>authentication == &quot;1&quot;:</body>
                                            </command>
                                            <nestedSteps>
                                                <item guid="b37bde17-742d-4e2a-b043-9a1c6d402300" action="eval" useFieldsInCommand="false">
                                                    <command>
                                                        <body>authentication = &quot;HMAC-SHA-1-96 [RFC2404]&quot;</body>
                                                    </command>
                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                </item>
                                            </nestedSteps>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="faf36c7b-99e7-4509-b48f-bbde57534b50" action="elif" useFieldsInCommand="false">
                                            <command>
                                                <body>authentication == &quot;0&quot;:</body>
                                            </command>
                                            <nestedSteps>
                                                <item guid="b37bde17-742d-4e2a-b043-9a1c6d402300" action="eval" useFieldsInCommand="false">
                                                    <command>
                                                        <body>authentication = &quot;HMAC-MD5-96 [RFC2403]&quot;</body>
                                                    </command>
                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                </item>
                                            </nestedSteps>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="2f5b861a-a1c0-4f12-b02d-470191452fb9" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>GET ip and spi</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="683abca9-b32a-4c85-9b10-4c9fd0f81ad8" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>ip = &quot;*&quot;</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="0a58fc63-60de-4d48-a2d5-8b318997c06c" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>spi_1 = re.search(spi_pattern,esp_encryption_key_1).group(1)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="cdf3f687-7343-4e1a-85b6-a2f310ea2b15" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>spi_2 = re.search(spi_pattern,esp_encryption_key_2).group(1)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="d99a4339-9622-4e97-b79c-b4b24e67625f" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>Get encryption_key and authentication_key (this key can use for both spis)</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="3056a3ce-772e-42d0-921a-d76c7d55851b" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>encryption_key = re.search(encryption_key_pattern,esp_encryption_key_1).group(1)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="28b4a9b4-1889-44a2-a115-7e0491fb622e" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>authentication_key = re.search(authentication_key_pattern,esp_encryption_key_1).group(1)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="213e4e1c-eae2-466c-9f6b-fd4cf6b53d7e" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>wireshark display filter command</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="4ca51977-6818-49a9-954d-a2ab8bb4172c" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>valid_key = f&apos;-o esp.enable_encryption_decode:TRUE -o &quot;uat:esp_sa:\\\\&quot;{ip_version}\\\\&quot;,\\\\&quot;{ip}\\\\&quot;,\\\\&quot;{ip}\\\\&quot;,\\\\&quot;{spi_1}\\\\&quot;,\\\\&quot;{encryption}\\\\&quot;,\\\\&quot;{encryption_key}\\\\&quot;,\\\\&quot;{authentication}\\\\&quot;,\\\\&quot;{authentication_key}\\\\&quot;&quot; -o &quot;uat:esp_sa:\\\\&quot;{ip_version}\\\\&quot;,\\\\&quot;{ip}\\\\&quot;,\\\\&quot;{ip}\\\\&quot;,\\\\&quot;{spi_2}\\\\&quot;,\\\\&quot;{encryption}\\\\&quot;,\\\\&quot;{encryption_key}\\\\&quot;,\\\\&quot;{authentication}\\\\&quot;,\\\\&quot;{authentication_key}\\\\&quot;&quot;&apos;</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="aedaf7fe-1221-4919-9b07-2a5ea064878e" action="comment" useFieldsInCommand="false">
                                            <command>
                                                <body>Change the encryption key to invalid</body>
                                            </command>
                                            <nestedSteps>
                                                <item guid="a40984c7-3c7d-49cc-bb3b-aa83edbd2cc8" action="eval" useFieldsInCommand="false">
                                                    <command>
                                                        <body>encryption_key=encryption_key[:-1]</body>
                                                    </command>
                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                </item>
                                            </nestedSteps>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="83ac5002-9fdb-4727-86e7-42ae3ab5909a" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>invalid_key = f&apos;-o esp.enable_encryption_decode:TRUE -o &quot;uat:esp_sa:\\\\&quot;{ip_version}\\\\&quot;,\\\\&quot;{ip}\\\\&quot;,\\\\&quot;{ip}\\\\&quot;,\\\\&quot;{spi_1}\\\\&quot;,\\\\&quot;{encryption}\\\\&quot;,\\\\&quot;{encryption_key}\\\\&quot;,\\\\&quot;{authentication}\\\\&quot;,\\\\&quot;{authentication_key}\\\\&quot;&quot; -o &quot;uat:esp_sa:\\\\&quot;{ip_version}\\\\&quot;,\\\\&quot;{ip}\\\\&quot;,\\\\&quot;{ip}\\\\&quot;,\\\\&quot;{spi_2}\\\\&quot;,\\\\&quot;{encryption}\\\\&quot;,\\\\&quot;{encryption_key}\\\\&quot;,\\\\&quot;{authentication}\\\\&quot;,\\\\&quot;{authentication_key}\\\\&quot;&quot;&apos;</body>
                                            </command>
