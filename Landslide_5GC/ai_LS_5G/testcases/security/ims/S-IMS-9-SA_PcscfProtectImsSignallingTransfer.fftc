                        <item guid="711cd665-9810-4f8f-bd8c-a747d54628fc" action="else" useFieldsInCommand="false">
                            <nestedSteps>
                                <item guid="360b21d7-746d-4d84-bbeb-cba280a459b8" action="message" useFieldsInCommand="false">
