        <item name="extract_pcap_with_invalid_keys" isPublic="true">
            <steps>
                <item guid="068723ad-3b3b-464f-b6ce-cd78096a7242" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Get Pcap of Gm interface and Validate with invalid key</body>
                    </command>
                    <nestedSteps>
                        <item guid="409fd0ab-c9ea-459e-9b5c-3ccf7d24106c" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>pcap = &quot;&quot;</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="cb843e20-9bff-43ac-96bf-ec3d5604c26a" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>pcap = gget(&apos;pcap&apos;)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="e24996ab-de58-45fe-a181-153b7ce4abcb" action="if" useFieldsInCommand="false">
                            <command>
                                <body>pcap != &quot;&quot;:</body>
                            </command>
                            <nestedSteps>
                                <item guid="14dbb9d2-68b8-43fe-98b7-85a6516eca19" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>Validate</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="1eb14c0a-2814-4625-80e5-2c9eb32da713" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>pcap_name = gget(&apos;pcap_name&apos;)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="0c2e049b-b84d-4aa7-b3bb-b1f1d64f838a" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>print(pcap)</body>
                                            </command>
                                            <postProcessing>
                                                <analysisRules>
                                                    <item>
                                                        <extractorInfo extractorType="query">
                                                            <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                                <query>isEmpty</query>
                                                            </extractorProperties>
                                                        </extractorInfo>
                                                        <processorInfo ruleType="message">
                                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.MessageProcessorPropertyGroup" severity="Information">
                                                                <message>Analyzing data in pcap file: [pcap_name]</message>
                                                                <tag sub="false" defaultValue=""/>
                                                            </ruleProperties>
                                                        </processorInfo>
                                                    </item>
                                                </analysisRules>
                                            </postProcessing>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="68fc8686-009c-4d89-aaf5-c0dc0ae5c4ce" action="command" session="s5">
                                            <command>
                                                <body>query load &quot;[pcap]&quot;</body>
                                            </command>
                                            <postProcessing>
                                                <analysisRules>
                                                    <item>
                                                        <extractorInfo extractorType="query">
                                                            <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                                <query>responseLine()</query>
                                                            </extractorProperties>
                                                        </extractorInfo>
                                                        <processorInfo ruleType="assert">
                                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                                <expression>value == &quot;done&quot;</expression>
                                                                <actionsWhenFalse>
                                                                    <item actionId="FailTest">
                                                                        <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                    </item>
                                                                    <item actionId="DeclareExecutionIssue">
                                                                        <actionProperties type="com.fnfr.svt.execution.builtin.actions.ExecutionIssuePropertyGroup">
                                                                            <message>Can&apos;t load [pcap]</message>
                                                                        </actionProperties>
                                                                    </item>
                                                                    <item actionId="ExitProcedure">
                                                                        <actionProperties type="com.fnfr.svt.execution.builtin.actions.ExitProcedurePropertyGroup"/>
                                                                    </item>
                                                                </actionsWhenFalse>
                                                            </ruleProperties>
                                                        </processorInfo>
                                                    </item>
                                                </analysisRules>
                                            </postProcessing>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="3e6c6679-a88b-4cac-a74c-99760c72448e" action="comment" useFieldsInCommand="false">
                                            <command>
                                                <body>Find all ESP packets</body>
                                            </command>
                                            <nestedSteps>
                                                <item guid="f2b4caa5-32dc-4dec-a99d-ebf37423ee6d" action="eval" useFieldsInCommand="false">
                                                    <command>
                                                        <body>tag_key = &quot;ESP packets&quot;</body>
                                                    </command>
                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                </item>
                                                <item guid="6094cef5-2be1-414d-90aa-7b2bb1cd786e" action="eval" useFieldsInCommand="false">
                                                    <command>
                                                        <body>esp_packets_id_list = []</body>
                                                    </command>
                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                </item>
                                                <item guid="a944fad2-d10d-4b0d-98e7-932182779cf8" action="eval" useFieldsInCommand="false">
                                                    <command>
                                                        <body>gget(&apos;esp_packets_id_list&apos;)</body>
                                                    </command>
                                                    <postProcessing>
                                                        <analysisRules>
                                                            <item>
                                                                <extractorInfo extractorType="query">
                                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                                        <query>mapped/Json/item</query>
                                                                    </extractorProperties>
                                                                </extractorInfo>
                                                                <processorInfo ruleType="store">
                                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                                                        <storageLocation>esp_packets_id_list</storageLocation>
                                                                        <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                                                        <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                                                        <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                                                    </ruleProperties>
                                                                </processorInfo>
                                                            </item>
                                                        </analysisRules>
                                                    </postProcessing>
                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                </item>
                                                <item guid="55755e32-d030-4818-ae44-bfe93c95f74c" action="comment" useFieldsInCommand="false">
                                                    <command>
                                                        <body>Validate &quot;ESP packets are encrypted&quot;:</body>
                                                    </command>
                                                    <nestedSteps>
                                                        <item guid="cd012c77-5404-4a7f-8444-7cf942c11f48" action="eval" useFieldsInCommand="false">
                                                            <command>
                                                                <body>is_decrypted = &quot;false&quot;</body>
                                                            </command>
                                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                        </item>
                                                        <item guid="0733de31-67da-46d2-9f7f-36f0cd17bacc" action="for" useFieldsInCommand="false">
                                                            <command>
                                                                <body>id in esp_packets_id_list:</body>
                                                            </command>
                                                            <nestedSteps>
                                                                <item guid="289a173f-3543-455a-b309-f2f66fd7705a" action="command" session="s5">
                                                                    <command>
                                                                        <body>query details [id] pdml </body>
                                                                    </command>
                                                                    <postProcessing>
                                                                        <analysisRules>
                                                                            <item>
                                                                                <extractorInfo extractorType="query">
                                                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                                                        <query>success()</query>
                                                                                    </extractorProperties>
                                                                                </extractorInfo>
                                                                                <processorInfo ruleType="assert">
                                                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                                                        <expression>value == &quot;true&quot;</expression>
                                                                                        <actionsWhenFalse>
                                                                                            <item actionId="DeclareExecutionIssue">
                                                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.ExecutionIssuePropertyGroup">
                                                                                                    <message>Cannot query packet [id]</message>
                                                                                                </actionProperties>
                                                                                            </item>
                                                                                            <item actionId="FailTest">
                                                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                                            </item>
                                                                                            <item actionId="ExitProcedure">
                                                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.ExitProcedurePropertyGroup"/>
                                                                                            </item>
                                                                                            <item actionId="SkipRemainingRules">
                                                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                                            </item>
                                                                                        </actionsWhenFalse>
                                                                                    </ruleProperties>
                                                                                </processorInfo>
                                                                            </item>
                                                                            <item>
                                                                                <extractorInfo extractorType="query">
                                                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                                                        <query>boolean(//field[@name=&quot;frame.protocols&quot; and @show=&quot;eth:ethertype:ip:tcp:sip&quot;])</query>
                                                                                    </extractorProperties>
                                                                                </extractorInfo>
                                                                                <processorInfo ruleType="assert">
                                                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                                                        <expression>value == &quot;true&quot;</expression>
                                                                                        <actionsWhenTrue>
                                                                                            <item actionId="SkipRemainingRules">
                                                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                                            </item>
                                                                                        </actionsWhenTrue>
                                                                                    </ruleProperties>
                                                                                </processorInfo>
                                                                            </item>
                                                                            <item>
                                                                                <extractorInfo extractorType="query">
                                                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup" declareNoMatchIssue="false">
                                                                                        <query>boolean(//field[@name=&quot;sip.Supported&quot;])</query>
                                                                                    </extractorProperties>
                                                                                </extractorInfo>
                                                                                <processorInfo ruleType="assert">
                                                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                                                        <expression>str(value).lower() == &apos;false&apos;</expression>
                                                                                        <actionsWhenTrue>
                                                                                            <item actionId="DeclareExecutionIssue">
                                                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.ExecutionIssuePropertyGroup" severity="OK">
                                                                                                    <message>   ESP packet id &quot;[id]&quot; is NOT decrypted as expected</message>
                                                                                                </actionProperties>
                                                                                            </item>
                                                                                            <item actionId="PassTestIfNotAlreadyFailed">
                                                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                                            </item>
                                                                                        </actionsWhenTrue>
                                                                                        <actionsWhenFalse>
                                                                                            <item actionId="DeclareExecutionIssue">
                                                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.ExecutionIssuePropertyGroup" severity="Warning">
                                                                                                    <message>   ESP packet id &quot;[id]&quot; is decrypted successfully by an invalid key</message>
                                                                                                </actionProperties>
                                                                                            </item>
                                                                                            <item actionId="Eval">
                                                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                                                                                    <statement>is_decrypted = &quot;true&quot;</statement>
                                                                                                </actionProperties>
                                                                                            </item>
                                                                                            <item actionId="FailTest">
                                                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                                            </item>
                                                                                            <item actionId="SkipRemainingRules">
                                                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                                            </item>
                                                                                        </actionsWhenFalse>
                                                                                    </ruleProperties>
                                                                                </processorInfo>
                                                                            </item>
                                                                        </analysisRules>
                                                                    </postProcessing>
                                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                </item>
                                                            </nestedSteps>
                                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                        </item>
                                                        <item guid="b8f7695d-92c2-428e-ae80-1e0d19084021" action="if" useFieldsInCommand="false">
                                                            <command>
                                                                <body>is_decrypted == &quot;true&quot;:</body>
                                                            </command>
                                                            <nestedSteps>
                                                                <item guid="431c1cd8-491f-426b-b2f0-f55ec2ae3181" action="message" useFieldsInCommand="false">
                                                                    <command>
                                                                        <body>Warning:The signaling packets can still be decrypted with an invalid key</body>
                                                                    </command>
                                                                    <postProcessing>
                                                                        <analysisRules>
                                                                            <item>
                                                                                <extractorInfo extractorType="none">
                                                                                    <extractorProperties type="com.fnfr.svt.documents.EmptyExtractorPropertyGroup"/>
                                                                                </extractorInfo>
                                                                                <processorInfo ruleType="assert">
                                                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                                                        <expression>True</expression>
                                                                                        <actionsWhenTrue>
                                                                                            <item actionId="FailTest">
                                                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                                            </item>
                                                                                        </actionsWhenTrue>
                                                                                    </ruleProperties>
                                                                                </processorInfo>
                                                                            </item>
                                                                        </analysisRules>
                                                                    </postProcessing>
                                                                    <applicationProperties type="com.fnfr.svt.execution.builtin.exec.MessagePropertyGroup">
                                                                        <severity inherit="false">Warning</severity>
                                                                        <message inherit="false">The signaling packets can still be decrypted with an invalid key</message>
                                                                    </applicationProperties>
                                                                </item>
                                                            </nestedSteps>
                                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                        </item>
                                                        <item guid="0c1cc36b-7d33-4c92-8196-f7da98fd9a7f" action="else" useFieldsInCommand="false">
                                                            <nestedSteps>
                                                                <item guid="d21a0f44-948c-4990-a419-550ba1f7d017" action="message" useFieldsInCommand="false">
                                                                    <command>
                                                                        <body>OK:The signaling packets are encrypted, and the transported IMS signaling between the UE and IMS Node is protected</body>
                                                                    </command>
                                                                    <applicationProperties type="com.fnfr.svt.execution.builtin.exec.MessagePropertyGroup">
                                                                        <severity inherit="false">OK</severity>
                                                                        <message inherit="false">The signaling packets are encrypted, and the transported IMS signaling between the UE and IMS Node is protected</message>
                                                                    </applicationProperties>
                                                                </item>
                                                            </nestedSteps>
                                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                        </item>
                                                    </nestedSteps>
                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                </item>
                                            </nestedSteps>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="8fbcf0ab-c30e-4215-a5ef-feae01ca4fdb" action="else" useFieldsInCommand="false">
                            <nestedSteps>
                                <item guid="908c109c-760b-4673-9eff-f67e49220e30" action="message" useFieldsInCommand="false">
                                    <command>
                                        <body>Error:Pcap file for Gm interface not found</body>
                                    </command>
                                    <postProcessing>
                                        <analysisRules>
                                            <item>
                                                <extractorInfo extractorType="none">
                                                    <extractorProperties type="com.fnfr.svt.documents.EmptyExtractorPropertyGroup"/>
                                                </extractorInfo>
                                                <processorInfo ruleType="assert">
                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                        <expression>True</expression>
                                                        <actionsWhenTrue>
                                                            <item actionId="FailTest">
                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                            </item>
                                                        </actionsWhenTrue>
                                                    </ruleProperties>
                                                </processorInfo>
                                            </item>
                                        </analysisRules>
                                    </postProcessing>
                                    <applicationProperties type="com.fnfr.svt.execution.builtin.exec.MessagePropertyGroup">
                                        <severity inherit="false">Error</severity>
                                        <message inherit="false">Pcap file for Gm interface not found</message>
                                    </applicationProperties>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
            </steps>
            <arguments>
                <item name="nodal_pcaps">
                    <isMandatory>true</isMandatory>
                </item>
                <item name="is_b2b">
                    <defaultValue>True</defaultValue>
                    <isMandatory>true</isMandatory>
                </item>
                <item name="sut_pcaps"/>
                <item name="nodal_file_names">
                    <isMandatory>true</isMandatory>
