                <item guid="7d3eb90d-9350-4b73-bc4f-bf9fb501ecc5" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>IPV4 and IPV6 Classification</body>
                    </command>
                    <nestedSteps>
                        <item guid="fe2ab5e6-4928-4543-8af2-fd467c902e4a" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>gm_node_ip = param(&apos;LS_Nodal_favorite_params/TS1/ts0/tc0/MobileNodeAddr/ip&apos;, &apos;10.202.1.1&apos;); print(gm_node_ip);</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="3614a860-e3d3-4add-9fb9-eb36a9560c88" action="comment" useFieldsInCommand="false">
                            <command>
                                <body>Check if and set the ip version accordingly</body>
                            </command>
                            <nestedSteps>
                                <item guid="94ded6e9-aaca-4055-9d8b-e3305ea0853c" action="isIPv4" session="s1" useFieldsInCommand="false">
                                    <command>
                                        <body>(ip = gm_node_ip)</body>
                                    </command>
                                    <postProcessing>
                                        <analysisRules>
                                            <item>
                                                <extractorInfo extractorType="query">
                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                        <query>responseLine()</query>
                                                    </extractorProperties>
                                                </extractorInfo>
                                                <processorInfo ruleType="assert">
                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                        <expression>str(value).lower() == &quot;true&quot;</expression>
                                                        <actionsWhenTrue>
                                                            <item actionId="Eval">
                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                                                    <statement>ip_version = &quot;IPv4&quot;</statement>
                                                                </actionProperties>
                                                            </item>
                                                        </actionsWhenTrue>
                                                        <actionsWhenFalse>
                                                            <item actionId="Eval">
                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                                                    <statement>ip_version = &quot;IPv6&quot;</statement>
                                                                </actionProperties>
                                                            </item>
                                                        </actionsWhenFalse>
                                                    </ruleProperties>
                                                </processorInfo>
                                            </item>
                                        </analysisRules>
                                    </postProcessing>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="7ef10a1a-6e00-46d2-9eaa-c63f55b3b4af" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Get csv data information of the keypairs</body>
