                        <item guid="9db0dd09-a19b-4833-ac61-6d1545809319" action="comment" useFieldsInCommand="false">
                            <command>
                                <body>Show message if all criterias passed</body>
                            </command>
                            <nestedSteps>
                                <item guid="9db0dd09-3694-4f0c-bf17-6d1545809319" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>print(response)</body>
                                    </command>
                                    <postProcessing>
                                        <analysisRules>
                                            <item>
                                                <extractorInfo extractorType="query">
                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                        <query>result()</query>
                                                    </extractorProperties>
                                                </extractorInfo>
                                                <processorInfo ruleType="assert">
                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                        <expression>value == &quot;PASS&quot;</expression>
