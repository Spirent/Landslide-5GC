                                                        <body>action=&apos;setJsonValue&apos;, editResponseStructure=false, documentName=&apos;ts_groups&apos;, pathValue=&apos;{&quot;\\\\[[ts_used_index]]/is_reserve&quot;:true}&apos;</body>
