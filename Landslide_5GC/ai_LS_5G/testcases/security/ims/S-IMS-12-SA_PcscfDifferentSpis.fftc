                                <body>start_delay_time = param(&apos;TC_parameters/Start_Wait_Time&apos;,&quot;5&quot;)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="28b6dec3-ed36-4168-9460-7627b6af297f" action="perform_next_action" session="s1" useFieldsInCommand="false">
                            <command>
                                <body>(running_test_id=running_id, delay=start_delay_time, time_out=&apos;180&apos;, expected_state=&apos;2_Waiting&apos;, next_action=&apos;continue&apos;)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
