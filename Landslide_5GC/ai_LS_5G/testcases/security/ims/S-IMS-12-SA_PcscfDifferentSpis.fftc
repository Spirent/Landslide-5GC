                        <item guid="31ab3659-e69c-4488-a29e-02223a028c80" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>tas_api_url = &quot;{0}:443/api&quot;.format(tas_hostname if tas_hostname else tas_ipaddress)</body>
