                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="779f86a1-405d-4a76-8a60-8862f5066e81" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Waiting test for ready</body>
                    </command>
                    <nestedSteps>
                        <item guid="1dab8206-2d73-484e-9056-b220d582d993" action="waiting_for_test_get_expected_state" session="s1" useFieldsInCommand="false">
                            <command>
                                <body>(unexpected_states=&apos;ERROR;COMPLETE_ERROR&apos;, time_out=&apos;180&apos;, running_test_id=running_id, expected_state=&apos;2_Waiting&apos;)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="d8c3587a-80c8-471c-8311-6392494137f3" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Continue Emulated SUT</body>
                    </command>
                    <nestedSteps>
                        <item guid="56eb72ae-2835-4125-bba5-55ec5f98d935" action="if" useFieldsInCommand="false">
                            <command>
                                <body>is_b2b == &quot;true&quot;:</body>
                            </command>
                            <nestedSteps>
                                <item guid="2b203f22-c8a1-412c-9490-fc85d7cf6e1a" action="perform_next_action" session="s1" useFieldsInCommand="false">
                                    <command>
                                        <body>(running_test_id=running_node_id, delay=&apos;0&apos;, time_out=&apos;180&apos;, expected_state=&apos;2_Waiting&apos;, next_action=&apos;continue&apos;)</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="e73a8e5c-41c9-4d4f-952c-20b4542b6254" action="comment" useFieldsInCommand="false">
                            <command>
                                <body>Waiting test for ready</body>
                            </command>
                            <nestedSteps>
                                <item guid="bde145a6-0714-488e-a958-af96f55e4be9" action="waiting_for_test_get_expected_state" session="s1" useFieldsInCommand="false">
                                    <command>
                                        <body>(unexpected_states=&apos;ERROR;COMPLETE_ERROR&apos;, time_out=&apos;180&apos;, running_test_id=running_node_id, expected_state=&apos;RUNNING&apos;)</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="2c179d0b-838c-4d1d-a26f-3e1bad909620" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Continue Nodal Test</body>
                    </command>
