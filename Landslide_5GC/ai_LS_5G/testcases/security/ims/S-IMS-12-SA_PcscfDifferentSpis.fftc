                            </command>
                            <nestedSteps>
                                <item guid="f4b581db-66dc-49a8-b8b8-174dca11c67e" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>testcase_expected_states = [&quot;RUNNING&quot;, &quot;4_DELAY&quot;, &quot;STOPPING&quot;, &quot;CLEANUP&quot;, &quot;WAIT_FOR_TRANSFERS&quot;, &quot;FINAL&quot;, &quot;COMPLETE&quot;]</body>
                                    </command>
