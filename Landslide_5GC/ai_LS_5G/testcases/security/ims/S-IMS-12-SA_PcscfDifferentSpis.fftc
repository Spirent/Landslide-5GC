        <item name="extract_pcap_kpis" isPublic="true">
            <steps>
                <item guid="046747ab-834f-42aa-b325-0df614148861" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Valide Nodal pcaps</body>
                    </command>
                    <nestedSteps>
                        <item guid="4aa64425-f462-4dda-b56a-2d720c4a77d8" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>sut_ip = param(&apos;SUT/nodal_ts0_tc0/SipPCSCFAddr/name&apos;, &apos;10.202.100.1&apos;); print(sut_ip)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="55d11cf3-cf3a-49aa-b1e7-e66e8e9059fa" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>gm_phy = param(&apos;LS_Nodal_favorite_params/TS1/ts0/tc0/MobileNodeAddr/phy&apos;, &apos;eth2&apos;); print(gm_phy)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="a4c8c68a-55b8-46f0-87db-05f22ebb50b8" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>gm_node_ip = param(&apos;LS_Nodal_favorite_params/TS1/ts0/tc0/MobileNodeAddr/ip&apos;, &apos;10.202.1.1&apos;); print(gm_node_ip)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="e1e7c714-77ed-4d39-b874-a207520efc94" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>server_spi_raw = param(&apos;LS_Nodal_favorite_params/TS1/ts0/tc0/ImsSipSubsServerSpi&apos;, &apos;#(N256 0/2)&apos;); print(server_spi_raw)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="dfe8f3c5-8c3e-4a38-963f-7558713b2fb8" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>client_spi_raw = param(&apos;LS_Nodal_favorite_params/TS1/ts0/tc0/ImsSipSubsClientSpi&apos;, &apos;#(N257 0/2)&apos;); print(client_spi_raw)</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
