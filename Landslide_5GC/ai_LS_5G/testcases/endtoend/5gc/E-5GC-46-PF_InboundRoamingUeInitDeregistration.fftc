                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="6748a86a-c043-42a1-a062-f694776a01e3" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Get and calculate KPIs</body>
                    </command>
                    <nestedSteps>
                        <item guid="600239e2-1fa7-43ec-923a-f2bbdd4d886c" action="comment" useFieldsInCommand="false">
                            <command>
                                <body>Get Nodal KPIs from favorites</body>
                            </command>
                            <nestedSteps>
                                <item guid="95f808aa-c520-470c-be56-05ddd41a4cac" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>print(favorites)</body>
                                    </command>
                                    <postProcessing>
                                        <analysisRules>
                                            <item>
                                                <extractorInfo extractorType="query">
                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                        <query>count(mapped/Json/favorites/item)</query>
                                                    </extractorProperties>
                                                </extractorInfo>
                                                <processorInfo ruleType="assert">
                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                        <expression>int(value) &gt; 0</expression>
                                                        <actionsWhenFalse>
                                                            <item actionId="Eval">
                                                                <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                                                    <statement>pdusession_release_requests = pdusession_release_successes = pdusession_release_failures = ue_initiated_deregistration_requests = ue_initiated_deregistration_accepts = average_session_deregister_time__p_i__ = attempted_disconnect_rate__sessions_second___p_i__ = deregistration_rate__sessions_second___p_i__= &quot;&quot;</statement>
                                                                </actionProperties>
                                                            </item>
                                                            <item actionId="SkipRemainingRules">
                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                            </item>
                                                        </actionsWhenFalse>
                                                    </ruleProperties>
                                                </processorInfo>
                                            </item>
                                            <item>
                                                <extractorInfo extractorType="query">
                                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                        <query>running_id()</query>
                                                    </extractorProperties>
                                                </extractorInfo>
                                                <processorInfo ruleType="store">
                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                                        <storageLocation>running_id</storageLocation>
                                                        <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                                        <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                                        <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                                    </ruleProperties>
