                        </item>
                        <item guid="20985320-3875-4c76-a5fd-be4db7903733" action="else" useFieldsInCommand="false">
                            <nestedSteps>
                                <item guid="c2159a2c-7eaf-4825-93a3-9806d55fc1b3" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>This Test Failed</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="7cc14814-0080-4182-be0e-aa663b8691b7" action="message" useFieldsInCommand="false">
                                    <command>
                                        <body>Error:Sanity checking: Failed</body>
                                    </command>
                                    <postProcessing>
                                        <analysisRules>
                                            <item>
                                                <extractorInfo extractorType="none">
                                                    <extractorProperties type="com.fnfr.svt.documents.EmptyExtractorPropertyGroup"/>
                                                </extractorInfo>
                                                <processorInfo ruleType="assert">
                                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                        <expression>False</expression>
                                                        <actionsWhenFalse>
                                                            <item actionId="FailTest">
                                                                <actionProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                            </item>
                                                        </actionsWhenFalse>
                                                    </ruleProperties>
                                                </processorInfo>
                                            </item>
                                        </analysisRules>
                                    </postProcessing>
                                    <applicationProperties type="com.fnfr.svt.execution.builtin.exec.MessagePropertyGroup">
                                        <severity inherit="false">Error</severity>
                                        <message inherit="false">Sanity checking: Failed</message>
                                    </applicationProperties>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="55c03c69-b3a4-4f35-b78b-a7e58106d228" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Stop SUT session if B2B testing</body>
                    </command>
                    <nestedSteps>
                        <item guid="422e5f06-15ef-43fa-aa09-1e78b433e002" action="if" useFieldsInCommand="false">
                            <command>
                                <body>is_b2b == &quot;true&quot;:</body>
                            </command>
                            <nestedSteps>
                                <item guid="6ec4fbf2-a18d-49b6-a5ae-38c635152b2e" action="stop_or_abort_test" session="s1" useFieldsInCommand="false">
                                    <command>
                                        <body>(running_id=running_node_id, abort=should_abort, clean_up=clean_up, timeout=timeout)</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="2091d816-7d2a-4f83-9cf4-940ca614bf71" action="else" useFieldsInCommand="false">
                            <nestedSteps>
                                <item guid="6fc9bc72-7c7b-472f-b384-6336d0fdffd6" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>// TODO: Implement for E2E</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="2a5650d3-bfc0-4c5c-88ee-3ff53260ee85" action="return">
                    <command>
                        <body>[response]</body>
                    </command>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
            </steps>
            <arguments>
                <item name="run_data_list">
                    <isMandatory>true</isMandatory>
                </item>
                <item name="start_threshold_percent"/>
                <item name="optimistic_mode"/>
                <item name="session_capacity">
                    <isMandatory>true</isMandatory>
                </item>
                <item name="targeted_end_rate">
                    <isMandatory>true</isMandatory>
                </item>
                <item name="instance_number">
                    <defaultValue>1</defaultValue>
                    <isMandatory>true</isMandatory>
                </item>
                <item name="is_b2b">
                    <defaultValue>true</defaultValue>
                </item>
                <item name="running_node_id"/>
                <item name="node_run_data"/>
                <item name="restart_sut">
                    <defaultValue>true</defaultValue>
                </item>
                <item name="percentage_list"/>
                <item name="clean_up">
                    <defaultValue>false</defaultValue>
                </item>
                <item name="timeout">
                    <defaultValue>180</defaultValue>
                </item>
            </arguments>
            <response>{}</response>
        </item>
        <item name="execute_nodal_tests" isPublic="true">
            <steps>
                <item guid="ebeb495a-db6a-4d9e-824d-334102233dc3" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Calculate current rate, session capacity and test timer</body>
                    </command>
                    <nestedSteps>
                        <item guid="dc204edf-ae72-4843-9ad4-3b3980aee467" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>t_load_ts = 1 if int(session_capacity) == int(instance_number) else math.ceil(int(session_capacity)/int(instance_number))</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="4c9a3ed3-a3e8-4029-b174-ee68b0bef2ee" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>c_rate_ts = 1 if int(targeted_end_rate) == int(instance_number) else math.ceil(int(targeted_end_rate)/int(instance_number))</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="3fe203ea-2763-4c16-94c9-a2c26d8904b3" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>t_load_ts_list = []</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="16404969-4021-4bab-88bf-a50ee85ef329" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>c_rate_ts_list = []</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="038bfcc6-30ce-423f-b635-d087ec6e98d3" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>test_timer_ts = 0</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="4b4e9d62-84aa-4f91-a214-4e62fa6f959d" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>s_act_timer_ts = int(param(&quot;TC_parameters/Session_Active_Timer&quot;,120))</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="cc48c380-1f2d-4477-b73c-e4d5cea282d2" action="if" useFieldsInCommand="false">
                            <command>
                                <body>int(c_rate_ts) != 1:</body>
                            </command>
                            <nestedSteps>
                                <item guid="ff01bff4-1ff1-4dc4-95ff-7fc562c6461e" action="for" useFieldsInCommand="false">
                                    <command>
                                        <body>percent in percentage_list:</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="7cb7da02-3b17-474e-a4aa-bf3ae9b933c4" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>t_load_ts = int(percent * int(session_capacity) /100)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="b398a4a0-4f2d-4fba-86f6-aec48e2e972c" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>t_load_ts_list.append(t_load_ts)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="9eb57844-88cf-4ccb-9fae-9fb1cf70df6c" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>c_rate_ts = int(percent * int(targeted_end_rate) / 100)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="c0c98861-0e12-4f9d-91fe-96c12754cbd6" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>c_rate_ts_list.append(c_rate_ts)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="ac8175d3-ffa1-40cf-9d56-1e1613def486" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>current_test_timer_ts = (t_load_ts/c_rate_ts)*2 + s_act_timer_ts</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="c5dcae0c-4060-480f-8683-96c2c4c1d827" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>test_timer_ts = max(test_timer_ts, current_test_timer_ts)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="06dec13d-438f-4b6e-97b3-d1420ec9c77c" action="else" useFieldsInCommand="false">
                            <nestedSteps>
                                <item guid="026ccb0c-ac6c-4380-910b-eb95e23b4d93" action="for" useFieldsInCommand="false">
                                    <command>
                                        <body>percent in percentage_list:</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="9583a068-f06a-4519-9dc4-a4ee8df1ed49" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>t_load_ts_list.append(t_load_ts)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="c225903a-bd88-4332-8e38-606d46ca4797" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>c_rate_ts_list.append(c_rate_ts)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="9bf2a6f1-85d6-43cc-ad3d-19d1fc112071" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>current_test_timer_ts = (t_load_ts/c_rate_ts)*2 + s_act_timer_ts</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="e9049232-2e83-44ce-95d8-27ece4120354" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>test_timer_ts = max(test_timer_ts, current_test_timer_ts)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="4bf0daa6-66b1-482f-a15a-90e9db761349" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Show information</body>
                    </command>
                    <nestedSteps>
                        <item guid="d6069108-1ddf-4ba7-a100-918b20841ce5" action="if" useFieldsInCommand="false">
                            <command>
                                <body>str(is_sanity).lower() != &apos;true&apos;:</body>
                            </command>
                            <nestedSteps>
                                <item guid="f9f50341-405a-4a09-a2be-ddb12edc748d" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>rate = sum(c_rate_ts_list)</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="c85f4f3e-ba2a-4764-81bc-778ae2ac41dc" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>load = sum(t_load_ts_list)</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="3d516167-b453-4810-8a67-f55ed039d769" action="message" useFieldsInCommand="false">
                                    <command>
                                        <body>Information:Run test with c_rate_ts = &quot;[rate]&quot; Session(s)/sec and t_load_ts = &quot;[load]&quot; Session(s)</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.execution.builtin.exec.MessagePropertyGroup">
                                        <message inherit="false">Run test with c_rate_ts = &quot;[rate]&quot; Session(s)/sec and t_load_ts = &quot;[load]&quot; Session(s)</message>
                                    </applicationProperties>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="e628d307-886d-4ae4-bfd8-0d6e76689bea" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Configure for multiple instances</body>
                    </command>
                    <nestedSteps>
                        <item guid="0c97d6c4-fb03-4f0e-9059-13159577b51b" action="call" useFieldsInCommand="false">
                            <command>
                                <body>project://ai_LS_5G/utility_library/utils.fftc#auto_increment_5g_identifiers_for_multi_instances(run_data_list=run_data_list, t_load_ts_list=t_load_ts_list)</body>
                            </command>
                            <postProcessing>
                                <storeResponseAt>run_data_list</storeResponseAt>
                                <storeResponseText>true</storeResponseText>
                            </postProcessing>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="8e86d38c-0ee9-47cf-9300-c4d53a852a0a" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Run tests or update current running test</body>
                    </command>
                    <nestedSteps>
                        <item guid="585e10e9-4279-4d15-a398-8e2e36cf5f7f" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>running_id_list = []</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="d022b34f-e9e3-4ed1-8b56-672dbe5bbc82" action="for" useFieldsInCommand="false">
                            <command>
                                <body>idx, data in enumerate(run_data_list):</body>
                            </command>
                            <nestedSteps>
                                <item guid="741ddc5b-e028-4363-8583-bf62cc1c8ece" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>Enable port capture</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="19f82f69-a82e-467c-b7bf-f242d66c4edc" action="if" useFieldsInCommand="false">
                                            <command>
                                                <body>str(enable_port_capture) == &quot;True&quot;:</body>
                                            </command>
                                            <nestedSteps>
                                                <item guid="4a305c48-143d-486f-80b6-e0fcc1c096fe" action="enable_port_capture" session="s1" useFieldsInCommand="false">
                                                    <command>
                                                        <body>(run_data=data)</body>
                                                    </command>
                                                    <postProcessing>
                                                        <storeResponseAt>data</storeResponseAt>
                                                        <storeResponseText>true</storeResponseText>
                                                    </postProcessing>
                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                </item>
                                            </nestedSteps>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="c1d4037b-ab98-405d-b670-680de58b4a6b" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>Setting Sessions and StartRate</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="fcbd6121-ffde-462c-91b4-dfb84843a721" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>t_load_ts = t_load_ts_list[idx]</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="2f330b83-cbcc-43cc-9c0c-732e8495d099" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>c_rate_ts = c_rate_ts_list[idx]</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="f114db16-6898-4028-a552-9689d04d8049" action="configure_sessions_subscriber" session="s1" useFieldsInCommand="false">
                                            <command>
                                                <body>(run_data=data, session_capacity=t_load_ts, targeted_end_rate=c_rate_ts)</body>
                                            </command>
                                            <postProcessing>
                                                <storeResponseAt>data</storeResponseAt>
                                                <storeResponseText>true</storeResponseText>
                                            </postProcessing>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="823aa2a6-5257-4bd9-a62b-5e7735e62fe1" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>Run new test</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="820892a7-8a06-4327-8f1a-17408424fc09" action="run_test_using_run_data" session="s1" useFieldsInCommand="false">
                                            <command>
                                                <body>(run_data=data)</body>
