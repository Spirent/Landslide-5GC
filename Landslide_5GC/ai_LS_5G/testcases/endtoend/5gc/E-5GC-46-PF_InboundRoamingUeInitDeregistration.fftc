                                                                                    </command>
                                                                                    <applicationProperties type="com.fnfr.svt.execution.builtin.json.JsonPropertiesGroup" pathValue="{&quot;\\[[i]]/\\[[array_index]]&quot;:[kpis]}" pathValue.inherit="false" pathValue.sub="true">
                                                                                        <action inherit="false">addJsonNode</action>
                                                                                        <documentName inherit="false">response</documentName>
                                                                                    </applicationProperties>
                                                                                </item>
                                                                            </nestedSteps>
                                                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                                        </item>
                                                                    </nestedSteps>
