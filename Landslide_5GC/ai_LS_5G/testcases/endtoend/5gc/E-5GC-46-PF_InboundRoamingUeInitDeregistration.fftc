                                            <command>
                                                <body>project://ai_LS_5G/utility_library/utils.fftc#validate_percentage_list(percentage_list=percentage_list, session_capacity=session_capacity, targeted_end_rate=targeted_end_rate, threshold_percent=&apos;100&apos;, min_number_for_threshold=&apos;1&apos;)</body>
