                                    </applicationProperties>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="731a6ad0-993c-464e-9021-e7efdf0760c7" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Optimistic Mode is true, run 100% target</body>
                    </command>
                    <nestedSteps>
                        <item guid="80439552-0f35-4747-8ea7-48ef3e970832" action="if" useFieldsInCommand="false">
