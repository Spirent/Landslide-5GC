        <item name="build_charts" isPublic="true">
            <steps>
                <item guid="b99a6672-f3d0-4a25-b315-44b852a8ac37" action="eval" useFieldsInCommand="false">
                    <command>
                        <body>print(reportData)</body>
                    </command>
                    <postProcessing>
                        <analysisRules>
                            <item>
                                <extractorInfo extractorType="query">
                                    <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                        <query>count(mapped/Json/item)</query>
                                    </extractorProperties>
                                </extractorInfo>
                                <processorInfo ruleType="store">
                                    <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                        <storageLocation>instance_count</storageLocation>
                                        <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                        <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                        <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                    </ruleProperties>
                                </processorInfo>
                            </item>
                        </analysisRules>
                    </postProcessing>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="75849438-d04f-4a26-bfc4-e9af85372e43" action="eval" useFieldsInCommand="false">
                    <command>
                        <body>max_of_fail = 0</body>
                    </command>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="7d45f70e-873b-4be3-803b-f5eae6948087" action="for" useFieldsInCommand="false">
                    <command>
                        <body>i in range(0, int(instance_count)):</body>
                    </command>
                    <nestedSteps>
                        <item guid="b9a9b2d4-67eb-4c33-bcff-4a3e5e4effe3" action="comment" useFieldsInCommand="false">
                            <command>
                                <body>Insert steps here to be executed on each loop</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="21e0ee61-5246-4111-93a4-e04bf494c5b5" action="json" useFieldsInCommand="false">
                            <command>
                                <body>action=&apos;getJsonNode&apos;, editResponseStructure=false, documentName=&apos;reportData&apos;, pathValue=&apos;{&quot;[i]&quot;}&apos;</body>
                            </command>
                            <postProcessing>
                                <analysisRules>
                                    <item>
                                        <extractorInfo extractorType="query">
                                            <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                <query>count(mapped/Json/item)</query>
                                            </extractorProperties>
                                        </extractorInfo>
                                        <processorInfo ruleType="store">
                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.StoreProcessorPropertyGroup">
                                                <storageLocation>countTimesRun</storageLocation>
                                                <responseValue type="com.fnfr.documents.PropertyBoolean">false</responseValue>
                                                <variable type="com.fnfr.documents.PropertyBoolean">true</variable>
                                                <secret type="com.fnfr.documents.PropertyBoolean">false</secret>
                                            </ruleProperties>
                                        </processorInfo>
                                    </item>
                                    <item>
                                        <extractorInfo extractorType="query">
                                            <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                <query>count(mapped/Json/item[result=&quot;FAIL&quot;])</query>
                                            </extractorProperties>
                                        </extractorInfo>
                                        <processorInfo ruleType="assert">
                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                <expression>int(value) &gt; int(max_of_fail)</expression>
                                                <actionsWhenTrue>
                                                    <item actionId="Eval">
                                                        <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                                            <statement>max_of_fail = int(value)</statement>
                                                        </actionProperties>
                                                    </item>
                                                </actionsWhenTrue>
                                            </ruleProperties>
                                        </processorInfo>
                                    </item>
                                </analysisRules>
                                <storeResponseAt>report_data_instance[i]</storeResponseAt>
                                <storeResponseText>true</storeResponseText>
                            </postProcessing>
                            <applicationProperties type="com.fnfr.svt.execution.builtin.json.JsonPropertiesGroup" pathValue="{&quot;[i]&quot;}" pathValue.inherit="false" pathValue.sub="true">
                                <action inherit="false">getJsonNode</action>
                                <documentName inherit="false" sub="true">reportData</documentName>
                            </applicationProperties>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="309e896a-49db-4877-8c5a-901a992881c9" action="if" useFieldsInCommand="false">
                    <command>
                        <body>int(max_of_fail) &gt; 1 :</body>
                    </command>
                    <nestedSteps>
                        <item guid="afbd91d9-db00-4acd-9fbc-b41c91c88254" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>countTimesRun = int(countTimesRun) -1</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="1abfb805-ed8f-40f7-9ca3-feea5f6a08ac" action="for" useFieldsInCommand="false">
                    <command>
                        <body>i in range(0, int(instance_count)):</body>
                    </command>
                    <nestedSteps>
                        <item guid="30ba0c5d-ebe6-45b7-8f65-205f6e01aa13" action="comment" useFieldsInCommand="false">
                            <command>
                                <body>Build charts for each instance test.</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="956dbfc0-85cf-41c6-981c-c882558962d5" action="json" useFieldsInCommand="false">
                            <command>
                                <body>action=&apos;getJsonNode&apos;, editResponseStructure=false, documentName=&apos;reportData&apos;, pathValue=&apos;{&quot;[i]&quot;}&apos;</body>
                            </command>
                            <postProcessing>
                                <storeResponseAt>report_data_instance[i]</storeResponseAt>
                                <storeResponseText>true</storeResponseText>
                            </postProcessing>
                            <applicationProperties type="com.fnfr.svt.execution.builtin.json.JsonPropertiesGroup" pathValue="{&quot;[i]&quot;}" pathValue.inherit="false" pathValue.sub="true">
                                <action inherit="false">getJsonNode</action>
                                <documentName inherit="false" sub="true">reportData</documentName>
                            </applicationProperties>
                        </item>
                        <item guid="3942fc5e-ec7f-43c9-87d3-937d3150c302" action="for" useFieldsInCommand="false">
                            <command>
                                <body>j in range(0, int(countTimesRun)):</body>
                            </command>
                            <nestedSteps>
                                <item guid="097589a9-f601-40fe-b014-f7e28c9fca79" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>Build chart</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="2373a892-43d3-49cd-b560-dbfe1b518a35" action="json" useFieldsInCommand="false">
                                            <command>
                                                <body>action=&apos;getJsonNode&apos;, editResponseStructure=false, documentName=&apos;report_data_instance[i]&apos;, pathValue=&apos;{&quot;[j]&quot;}&apos;</body>
                                            </command>
                                            <postProcessing>
                                                <analysisRules>
                                                    <item>
                                                        <extractorInfo extractorType="query">
                                                            <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                                <query>c_rate()</query>
                                                            </extractorProperties>
                                                        </extractorInfo>
                                                        <processorInfo ruleType="assert">
                                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                                <expression>value == &quot;&quot; or value == &quot;_&quot;</expression>
                                                                <actionsWhenTrue>
                                                                    <item actionId="Eval">
                                                                        <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                                                            <statement>attempted = 0</statement>
                                                                        </actionProperties>
                                                                    </item>
                                                                </actionsWhenTrue>
                                                                <actionsWhenFalse>
                                                                    <item actionId="Eval">
                                                                        <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                                                            <statement>attempted = value</statement>
                                                                        </actionProperties>
                                                                    </item>
                                                                </actionsWhenFalse>
                                                            </ruleProperties>
                                                        </processorInfo>
                                                    </item>
                                                    <item>
                                                        <extractorInfo extractorType="query">
                                                            <extractorProperties type="com.fnfr.svt.mapping.execution.extractors.QueryDataExtractorPropertyGroup">
                                                                <query>//item[name=&apos;Actual Deregister rate&apos;]/value</query>
                                                            </extractorProperties>
                                                        </extractorInfo>
                                                        <processorInfo ruleType="assert">
                                                            <ruleProperties type="com.fnfr.svt.execution.builtin.processors.AssertionPropertyGroup">
                                                                <expression>value == &quot;&quot; or value == &quot;_&quot;</expression>
                                                                <actionsWhenTrue>
                                                                    <item actionId="Eval">
                                                                        <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                                                            <statement>actual = 0</statement>
                                                                        </actionProperties>
                                                                    </item>
                                                                </actionsWhenTrue>
                                                                <actionsWhenFalse>
                                                                    <item actionId="Eval">
                                                                        <actionProperties type="com.fnfr.svt.execution.builtin.actions.EvalActionPropertyGroup">
                                                                            <statement>actual = value</statement>
                                                                        </actionProperties>
                                                                    </item>
                                                                </actionsWhenFalse>
                                                            </ruleProperties>
                                                        </processorInfo>
                                                    </item>
                                                    <item>
                                                        <extractorInfo extractorType="none">
                                                            <extractorProperties type="com.fnfr.svt.documents.EmptyExtractorPropertyGroup"/>
                                                        </extractorInfo>
                                                        <processorInfo ruleType="chart_as_xy">
                                                            <ruleProperties type="com.fnfr.svt.execution.charting.processors.ChartUsingXYPropertyGroup" chartName="Attempted vs Actual Deregister rate - Nodal Instance [i]" style="LINE" xAxisLabel="Number of attempted Deregister rate (sessions/s)" yAxisLabel="Number of actual Deregister rate (sessions/s)" highlightDataPoint="true" series="Number of Deregister rate">
                                                                <title>Attempted vs Actual Deregister rate</title>
                                                                <xValue>round(float(attempted),5)</xValue>
                                                                <yValue>round(float(actual),5)</yValue>
                                                            </ruleProperties>
                                                        </processorInfo>
                                                    </item>
                                                </analysisRules>
                                            </postProcessing>
                                            <applicationProperties type="com.fnfr.svt.execution.builtin.json.JsonPropertiesGroup" pathValue="{&quot;[j]&quot;}" pathValue.inherit="false" pathValue.sub="true">
                                                <action inherit="false">getJsonNode</action>
                                                <documentName inherit="false" sub="true">report_data_instance[i]</documentName>
                                            </applicationProperties>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
            </steps>
            <arguments>
                <item name="reportData">
                    <description>All reports to all execution times. It should include both passed/failed cases.</description>
                    <isMandatory>true</isMandatory>
                </item>
            </arguments>
            <response>{}</response>
        </item>
        <item name="summarize_test_before_run" isPublic="true">
            <steps>
                <item guid="c248cc78-12cf-4a3b-a1a8-51f09ac61fbb" action="call" useFieldsInCommand="false">
                    <command>
                        <body>project://ai_LS_5G/utility_library/utils.fftc#insert_devider_string(char=&apos;=&apos;, length=&apos;80&apos;)</body>
                    </command>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="5174724e-248c-46c9-b29e-a06618fbf1a6" action="message" useFieldsInCommand="false">
                    <command>
                        <body>Information:The PDU Session activation rate (t_rate) in terms of simultaneous Deregistration per second: &quot;[targeted_end_rate]&quot; Session(s)/sec</body>
                    </command>
                    <applicationProperties type="com.fnfr.svt.execution.builtin.exec.MessagePropertyGroup">
                        <message inherit="false">The PDU Session activation rate (t_rate) in terms of simultaneous Deregistration per second: &quot;[targeted_end_rate]&quot; Session(s)/sec</message>
                    </applicationProperties>
                </item>
                <item guid="7660a933-1f09-4cc5-b177-db10c456397d" action="message" useFieldsInCommand="false">
                    <command>
                        <body>Information:The targeted load (t_load) in terms of Deregistration: &quot;[session_capacity]&quot; Session(s)</body>
                    </command>
                    <applicationProperties type="com.fnfr.svt.execution.builtin.exec.MessagePropertyGroup">
                        <message inherit="false">The targeted load (t_load) in terms of Deregistration: &quot;[session_capacity]&quot; Session(s)</message>
                    </applicationProperties>
                </item>
                <item guid="fcedfc2a-fa62-4368-85e6-3ff141392c0e" action="call" useFieldsInCommand="false">
                    <command>
                        <body>project://ai_LS_5G/utility_library/utils.fftc#insert_devider_string(char=&apos;=&apos;, length=&apos;80&apos;)</body>
                    </command>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
            </steps>
            <arguments>
                <item name="targeted_end_rate">
                    <isMandatory>true</isMandatory>
                </item>
                <item name="session_capacity"/>
            </arguments>
            <response>{}</response>
        </item>
