                                        </item>
                                        <item guid="fae7036a-41c7-4264-a225-c1aee31e5901" action="if" useFieldsInCommand="false">
                                            <command>
                                                <body>error:</body>
                                            </command>
                                            <nestedSteps>
                                                <item guid="09ee8cfb-3331-408a-a074-dbbe13565f3d" action="if" useFieldsInCommand="false">
                                                    <command>
                                                        <body>int(session_capacity) == int(instance_number):</body>
