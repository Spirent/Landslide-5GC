                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="cf99728b-af39-44e5-ae24-348d6cb858d8" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Optimistic Mode is true, run 100% target</body>
