                                                        <item guid="cdfa5c2c-8189-4cc3-b2fc-d95f5bc16559" action="if" useFieldsInCommand="false">
                                                            <command>
                                                                <body>is_b2b == &quot;true&quot; and running_node_id:</body>
                                                            </command>
                                                            <nestedSteps>
                                                                <item guid="8225c93b-67d5-4f0f-9a01-32449cdaf021" action="stop_or_abort_test" session="s1" useFieldsInCommand="false">
