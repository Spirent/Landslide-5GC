                                </item>
                                <item guid="61283121-03f1-43b6-a106-72ce57bae435" action="message" useFieldsInCommand="false">
                                    <command>
                                        <body>Error:Sanity checking: Failed</body>
                                    </command>
                                    <postProcessing>
                                        <analysisRules>
