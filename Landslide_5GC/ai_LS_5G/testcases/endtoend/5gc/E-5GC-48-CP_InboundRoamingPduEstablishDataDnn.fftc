                <item guid="a52eb7b5-0a7b-4a19-abbc-af8e9d258203" action="return">
                    <command>
                        <body>[response]</body>
                    </command>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
            </steps>
            <arguments>
                <item name="run_data_list">
                    <isMandatory>true</isMandatory>
                </item>
                <item name="start_threshold_percent"/>
                <item name="optimistic_mode"/>
                <item name="session_capacity">
                    <isMandatory>true</isMandatory>
                </item>
                <item name="targeted_end_rate">
                    <isMandatory>true</isMandatory>
                </item>
                <item name="instance_number">
                    <defaultValue>1</defaultValue>
                    <isMandatory>true</isMandatory>
                </item>
                <item name="is_b2b">
                    <defaultValue>true</defaultValue>
                </item>
                <item name="running_node_id"/>
                <item name="node_run_data"/>
                <item name="restart_sut">
                    <defaultValue>true</defaultValue>
                </item>
                <item name="percentage_list"/>
                <item name="clean_up">
                    <defaultValue>false</defaultValue>
                </item>
                <item name="timeout">
                    <defaultValue>180</defaultValue>
                </item>
            </arguments>
            <response>{}</response>
        </item>
        <item name="execute_nodal_tests" isPublic="true">
            <steps>
                <item guid="4c4381b6-57d8-44a2-adcf-6b19cd7c723d" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Calculate current rate, session capacity and test timer</body>
                    </command>
                    <nestedSteps>
                        <item guid="7f8af3a9-d3a2-4e25-935b-c7f5a99d3c3b" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>t_load_ts = 1 if int(session_capacity) == int(instance_number) else math.ceil(int(session_capacity)/int(instance_number))</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="c836490e-862b-463d-b542-1c767e7c15a5" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>c_rate_ts = 1 if int(targeted_end_rate) == int(instance_number) else math.ceil(int(targeted_end_rate)/int(instance_number))</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="b138d778-aa85-44cf-b2e3-c59c3f9c41d6" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>t_load_ts_list = []</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="4c2fca3e-d660-4c18-9487-38af29d76301" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>c_rate_ts_list = []</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="87b27a9a-4146-4f73-b170-11f04222d41a" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>test_timer_ts = 0</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="a14f9386-39f8-4b88-8b8e-825f3075237c" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>s_act_timer_ts = int(param(&quot;TC_parameters/Session_Active_Timer&quot;,120))</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="98a09385-9e39-40dd-bae1-2a4a8a7b616f" action="if" useFieldsInCommand="false">
                            <command>
                                <body>int(c_rate_ts) != 1:</body>
                            </command>
                            <nestedSteps>
                                <item guid="973ae186-07bc-4b4c-991e-80d4639e48c4" action="for" useFieldsInCommand="false">
                                    <command>
                                        <body>percent in percentage_list:</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="dcece434-74a1-4976-80a0-b13be8a5ccdc" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>t_load_ts = int(percent * int(session_capacity) /100)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="6f9887fc-b2df-49ba-ac57-f33c534d2be6" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>t_load_ts_list.append(t_load_ts)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="50999be4-a955-478f-b78f-653d4252a83e" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>c_rate_ts = int(percent * int(targeted_end_rate) / 100)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="bc60b322-4b5c-4c1a-9065-7cada468b6bb" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>c_rate_ts_list.append(c_rate_ts)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="88de2ff0-5a8a-4535-94e4-3bda9a00840f" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>current_test_timer_ts = (t_load_ts/c_rate_ts)*2 + s_act_timer_ts</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="92a4bb0b-cdf1-4d25-abe0-77266df9a5bc" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>test_timer_ts = max(test_timer_ts, current_test_timer_ts)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="5997851c-cd48-46a3-b613-8daa1266e3b3" action="else" useFieldsInCommand="false">
                            <nestedSteps>
                                <item guid="b93a8760-54b7-473e-a873-1dd059d812c8" action="for" useFieldsInCommand="false">
                                    <command>
                                        <body>percent in percentage_list:</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="db7fa4d7-1343-4eea-ace5-c17056fb171a" action="eval" skip="true" useFieldsInCommand="false">
                                            <command>
                                                <body>t_load_ts = 2</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="2463b0ea-0a21-44f7-919b-459e68c57c33" action="eval" skip="true" useFieldsInCommand="false">
                                            <command>
                                                <body>c_rate_ts = 2</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="50243226-a7a7-425c-a0f3-419a47616b22" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>t_load_ts_list.append(t_load_ts)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="1dda58f1-58f0-4ce3-816a-6b93691bf46d" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>c_rate_ts_list.append(c_rate_ts)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="b1da0f52-b358-4564-9e64-68671e91c80c" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>current_test_timer_ts = (t_load_ts/c_rate_ts)*2 + s_act_timer_ts</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="b341bf7b-89f6-41f2-a389-61951e8ef6d7" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>test_timer_ts = max(test_timer_ts, current_test_timer_ts)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="433cf025-ca47-411f-929e-58cd8d091cc8" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Show information</body>
                    </command>
                    <nestedSteps>
                        <item guid="d8893290-fd9c-4554-b9f7-ce9b811c1e43" action="if" useFieldsInCommand="false">
                            <command>
                                <body>str(is_sanity).lower() != &apos;true&apos;:</body>
                            </command>
                            <nestedSteps>
                                <item guid="718174be-028c-4eda-bed6-e69eb458a4c5" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>rate = sum(c_rate_ts_list)</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="89299229-b8ca-47c7-b4c8-c5b41ad952bb" action="eval" useFieldsInCommand="false">
                                    <command>
                                        <body>load = sum(t_load_ts_list)</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="bdb9199a-1da3-4d3e-a0f8-ed1a3b6603c1" action="message" useFieldsInCommand="false">
                                    <command>
                                        <body>Information:Run test with c_rate_ts = &quot;[rate]&quot; Session(s)/sec and t_load_ts = &quot;[load]&quot; Session(s)</body>
                                    </command>
                                    <applicationProperties type="com.fnfr.svt.execution.builtin.exec.MessagePropertyGroup">
                                        <message inherit="false">Run test with c_rate_ts = &quot;[rate]&quot; Session(s)/sec and t_load_ts = &quot;[load]&quot; Session(s)</message>
                                    </applicationProperties>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="fee89756-7ebc-41b2-8d0e-f1f9324cd1a9" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Configure for multiple instances</body>
                    </command>
                    <nestedSteps>
                        <item guid="21a18430-42fe-40ac-883f-db76c9033a15" action="call" useFieldsInCommand="false">
                            <command>
                                <body>project://ai_LS_5G/utility_library/utils.fftc#auto_increment_5g_identifiers_for_multi_instances(run_data_list=run_data_list, t_load_ts_list=t_load_ts_list)</body>
                            </command>
                            <postProcessing>
                                <storeResponseAt>run_data_list</storeResponseAt>
                                <storeResponseText>true</storeResponseText>
                            </postProcessing>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                    </nestedSteps>
                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                </item>
                <item guid="e2a1f600-c71c-4292-8f82-434c925b8deb" action="comment" useFieldsInCommand="false">
                    <command>
                        <body>Run tests or update current running test</body>
                    </command>
                    <nestedSteps>
                        <item guid="1094703c-e7d6-40c8-857d-076d9c33faa2" action="eval" useFieldsInCommand="false">
                            <command>
                                <body>running_id_list = []</body>
                            </command>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="097d2ce5-59bc-4b74-b32a-14e8d5f28b67" action="for" useFieldsInCommand="false">
                            <command>
                                <body>idx, data in enumerate(run_data_list):</body>
                            </command>
                            <nestedSteps>
                                <item guid="75199b4d-da40-4060-94ca-bf544c7e9b26" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>Enable port capture</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="f2b6effc-5081-4d37-9e0f-a9c562c4c357" action="if" useFieldsInCommand="false">
                                            <command>
                                                <body>str(enable_port_capture) == &quot;True&quot;:</body>
                                            </command>
                                            <nestedSteps>
                                                <item guid="ed7fea79-ea12-4fc2-88dc-eff9c8b9925c" action="enable_port_capture" session="s1" useFieldsInCommand="false">
                                                    <command>
                                                        <body>(run_data=data)</body>
                                                    </command>
                                                    <postProcessing>
                                                        <storeResponseAt>data</storeResponseAt>
                                                        <storeResponseText>true</storeResponseText>
                                                    </postProcessing>
                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                </item>
                                            </nestedSteps>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="383d504e-7339-41cc-95f4-347ff06d0ee5" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>Update automation control</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="9de3f7dd-97d2-4c1f-ace9-4cfc6d9213c3" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>automation_steps = &quot;0:3:Init:-1:-1::0;0:2:Init:-1:-1::0;0:1:Init:-1:-1::0;0:3:Start:-1:-1::0;0:2:Start:0:3:RUNNING:0;0:1:Start:0:2:RUNNING:0;0:0:Init:0:1:RUNNING:0;-4:-4::-1:-1::0;0:0:Start:-1:-1::0;0:0:Stop:0:0:RUNNING:{0};0:0:Cleanup:0:0:STOPPED:0;0:1:Stop:-1:-1::0;0:1:Cleanup:0:1:STOPPED:0;0:2:Stop:-1:-1::0;0:2:Cleanup:0:2:STOPPED:0;0:3:Stop:-1:-1::0;0:3:Cleanup:0:3:STOPPED:0&quot;.format(s_act_timer_ts)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="885c39bd-4be6-49f0-8f5a-2fa278d132b3" action="update_automation_control_step" session="s1" useFieldsInCommand="false">
                                            <command>
                                                <body>(run_data=data, steps=automation_steps)</body>
                                            </command>
                                            <postProcessing>
                                                <storeResponseAt>data</storeResponseAt>
                                                <storeResponseText>true</storeResponseText>
                                            </postProcessing>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="00682092-911e-4d62-80b9-a39b3006c7dc" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>Setting Sessions and StartRate</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="3b00ff3b-f863-4a9f-8787-ab203aa7cd6a" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>t_load_ts = t_load_ts_list[idx]</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="88481eff-4de7-46d1-bf40-fe03f8a1eae5" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>c_rate_ts = c_rate_ts_list[idx]</body>
                                            </command>
